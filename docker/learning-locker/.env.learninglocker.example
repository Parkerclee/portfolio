# Learning Locker app env (copied into the container).
# These values are for local development only.

# Port mapping inside the container:
# - UI server (Safari should load this): http://localhost:3000
# - Learning Locker API:              http://localhost:8081
# - xAPI HTTP interface (xapi-service): http://localhost:8080/data/xAPI/*
UI_PORT=3000
API_PORT=8081
SITE_URL=http://localhost:3000

# Required. Use a long random string (at least ~32 chars).
APP_SECRET=change-me-to-a-long-random-string

# Required: point LL at the Compose services.
MONGODB_PATH=mongodb://learninglocker-mongo:27017/learninglocker_v2
REDIS_URL=redis://learninglocker-redis:6379/0

# Legacy variable some setups still reference.
DOMAIN_NAME=localhost

# Queue provider used by worker/scheduler.
QUEUE_PROVIDER=REDIS
QUEUE_NAMESPACE=DEV

# Email is optional for local; leaving blank disables email flows.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURED=
SMTP_USER=
SMTP_PASS=
