---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';

const allEntries = await getCollection('case-studies', ({ data }) => !data.draft);
allEntries.sort((a, b) => a.data.order - b.data.order);
const featuredEntries = allEntries.filter(e => !e.data.aiGenerated).slice(0, 3);

// Bite-size craft previews — earlier production work, shown as quick "A → B" cards.
const craft = [
  {
    label: 'E-Learning',
    move: 'Skill gap → confident reps',
    blurb: 'Rise & Storyline courses and interactive software simulators — from a B2B mattress-sales course to a safe order-management sandbox built because the real system had none.',
    tools: ['Storyline', 'Rise 360'],
    image: '/work/elearning-purple-mattresses.webp',
    alt: 'Rise course interface for a Purple mattress sales-enablement training',
    link: 'https://rise.articulate.com/share/BGBwMTQOWH1Pm_yojY-ZvBI-DBFDfszr',
    linkLabel: 'View a live course',
    tile: '',
  },
  {
    label: 'Animation',
    move: 'Flat content → branded motion',
    blurb: 'An animated identity for the L&D team, plus reusable motion-graphic templates (lower thirds, title cards) and a Six Sigma 5S manufacturing series.',
    tools: ['After Effects', 'Illustrator'],
    image: '/work/animation-ld-logo.webp',
    alt: 'Animated Purple Learning & Development logo',
    link: '',
    linkLabel: '',
    tile: '',
  },
  {
    label: 'Video',
    move: 'Dry memo → watchable',
    blurb: 'Knowledge-base walkthroughs, a learning podcast with a senior data scientist, conference sizzle reels, and an employee tuition-reimbursement featurette — shot and cut in-house.',
    tools: ['Premiere', 'After Effects'],
    image: '',
    alt: '',
    link: '',
    linkLabel: '',
    tile: 'bg-primary-500',
  },
  {
    label: 'Branding',
    move: 'Scattered look → one system',
    blurb: 'Visual identity systems for learning programs and internal campaigns, so a growing library of content reads as one coherent brand.',
    tools: ['Illustrator'],
    image: '',
    alt: '',
    link: '',
    linkLabel: '',
    tile: 'bg-secondary-500',
  },
  {
    label: 'Job Aid Design',
    move: 'Long doc → one-glance aid',
    blurb: 'Print and digital job aids that put the right step in front of someone at the exact moment they need it — no scrolling through a manual.',
    tools: ['InDesign', 'Illustrator', 'Canva'],
    image: '',
    alt: '',
    link: '',
    linkLabel: '',
    tile: 'bg-accent-600',
  },
];
---
<BaseLayout
  title="Parker Lee — AI for L&D, Knowledge Management & Custom Training"
  bareTitle
  description="I help companies put AI to work in their L&D and knowledge management, and build custom AI training that changes how teams actually work."
>
  <Hero />


  <!-- What I Do Differently -->
  <section class="bg-paper py-14 sm:py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="fade-in max-w-2xl mx-auto text-center mb-12">
        <h2 class="font-display font-semibold text-3xl sm:text-4xl text-cocoa tracking-tight">
          How I help teams put <span class="italic text-primary-600">AI to work</span>
        </h2>
        <p class="mt-4 text-lg text-cocoa/70 leading-relaxed">
          Three ways companies bring me in to make AI useful in how their people learn and work.
        </p>
      </div>

      <div class="grid sm:grid-cols-3 gap-8">
        <div class="fade-in fade-in-delay-1 text-center sm:text-left">
          <div class="w-12 h-12 rounded-2xl bg-primary-100 text-primary-600 flex items-center justify-center mb-4 mx-auto sm:mx-0 border border-primary-200">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-display font-semibold text-lg text-cocoa mb-2">AI in your L&D</h3>
          <p class="text-sm text-cocoa/70 leading-relaxed">
            AI-powered learning experiences built in real code: simulations, branching scenarios,
            roleplay. Wired for xAPI, so you can see they changed behavior, not just completion.
          </p>
        </div>

        <div class="fade-in fade-in-delay-2 text-center sm:text-left">
          <div class="w-12 h-12 rounded-2xl bg-secondary-100 text-secondary-600 flex items-center justify-center mb-4 mx-auto sm:mx-0 border border-secondary-200">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
          </div>
          <h3 class="font-display font-semibold text-lg text-cocoa mb-2">AI for knowledge management</h3>
          <p class="text-sm text-cocoa/70 leading-relaxed">
            Turn the SOPs and tribal knowledge nobody reads into something people use in the flow
            of work, with AI surfacing the answers and the gaps made visible.
          </p>
        </div>

        <div class="fade-in fade-in-delay-3 text-center sm:text-left">
          <div class="w-12 h-12 rounded-2xl bg-accent-400/25 text-accent-700 flex items-center justify-center mb-4 mx-auto sm:mx-0 border border-accent-500/40">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
            </svg>
          </div>
          <h3 class="font-display font-semibold text-lg text-cocoa mb-2">Company-specific AI training</h3>
          <p class="text-sm text-cocoa/70 leading-relaxed">
            Custom training on your tools, your data, and your AI policies. Built for your context
            instead of a generic course, and measurable from day one.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- Case Studies -->
  <section id="case-studies" class="bg-cream-50 py-14 sm:py-20 border-t-2 border-cocoa/15">
    <div class="max-w-6xl mx-auto px-6">
      <div class="fade-in mb-12">
        <h2 class="font-display font-semibold text-3xl sm:text-4xl text-cocoa tracking-tight">
          Selected <span class="italic text-primary-600">case studies</span>
        </h2>
        <p class="mt-3 text-lg text-cocoa/70">
          Real work from financial services operations L&D. Anonymized, detailed, built to show how the decisions got made.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredEntries.map((entry, i) => (
          <div class={`fade-in fade-in-delay-${i + 1}`}>
            <CaseStudyCard
              company={entry.data.company}
              industry={entry.data.industry}
              challenge={entry.data.challenge}
              deliverable={entry.data.deliverable}
              color={entry.data.color}
              slug={entry.id}
              initials={entry.data.initials}
              aiGenerated={false}
            />
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="/case-studies" class="inline-flex items-center gap-2 text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">
          View all case studies, including concept pieces
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Craft & range (bite-size previews) -->
  <section id="craft" class="bg-paper py-14 sm:py-20 border-t-2 border-cocoa/15">
    <div class="max-w-6xl mx-auto px-6">
      <div class="fade-in mb-10">
        <span class="block-rule bg-accent-500 mb-4"></span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-cocoa tracking-tight">
          Beyond the case studies — <span class="text-primary-600">craft &amp; range</span>
        </h2>
        <p class="mt-3 text-lg text-cocoa/70 max-w-2xl">
          Before the strategy decks, I came up making things. A quick look at the range —
          video, motion, brand, and interactive courses — and how each one went from a problem to a finished piece.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {craft.map((item, i) => (
          <article class={`fade-in fade-in-delay-${(i % 3) + 1} flex flex-col rounded-2xl border-2 border-cocoa/15 bg-cream-50 overflow-hidden`}>
            {item.image ? (
              <img
                src={item.image}
                alt={item.alt}
                loading="lazy"
                class="w-full h-40 object-cover object-top border-b-2 border-cocoa/15"
              />
            ) : (
              <div class={`h-40 ${item.tile} flex items-center justify-center border-b-2 border-cocoa/15`}>
                <span class="font-display font-bold text-2xl text-cream/95 tracking-tight">{item.label}</span>
              </div>
            )}
            <div class="flex flex-col flex-1 p-5">
              <h3 class="font-display font-bold text-lg text-cocoa">{item.label}</h3>
              <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-primary-600">{item.move}</p>
              <p class="mt-2 text-sm text-cocoa/70 leading-relaxed flex-1">{item.blurb}</p>
              <div class="mt-4 flex flex-wrap items-center gap-1.5">
                {item.tools.map(t => (
                  <span class="inline-block px-2 py-0.5 rounded-full text-[11px] font-semibold bg-paper border border-cocoa/15 text-cocoa/70">{t}</span>
                ))}
              </div>
              {item.link && (
                <a href={item.link} target="_blank" rel="noopener"
                   class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">
                  {item.linkLabel}
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-espresso py-16">
    <div class="max-w-4xl mx-auto px-6 text-center relative">
      <h2 class="font-display font-semibold text-2xl sm:text-3xl text-cream">
        Want to see the learning experiences in action?
      </h2>
      <p class="mt-3 text-cream/80 text-lg">
        Shipped client courses and playable concept builds, in one place.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/demos"
           class="px-6 py-3 rounded-full bg-accent-500 text-espresso font-semibold retro-sheen
                  hover:bg-accent-400 transition-colors">
          Explore Live Demos
        </a>
        <a href="/dashboard"
           class="px-6 py-3 rounded-full border border-cream/40 text-cream font-semibold
                  hover:bg-cocoa transition-colors">
          View Analytics Dashboard
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
