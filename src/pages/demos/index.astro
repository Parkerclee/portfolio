---
import BaseLayout from '../../layouts/BaseLayout.astro';

const available = [
  {
    slug: 'practice-room',
    title: 'Practice Room · AI Roleplay',
    company: 'Leadership · behavior change',
    blurb: 'Practice a hard 1:1 with a teammate who reacts in the moment. A live read on how it lands, every turn streamed to the LRS, and an AI coaching debrief.',
    tag: 'AI roleplay · xAPI',
    color: 'terracotta',
    href: '/demos/practice-room',
  },
  {
    slug: 'skill-check',
    title: 'Skill Check · Adaptive Assessment',
    company: 'Compliance · measurement',
    blurb: 'A knowledge check that interviews instead of quizzing: open answers scored on substance, the last question spent on your weakest competency, mastery streamed as xAPI.',
    tag: 'AI assessment · xAPI',
    color: 'avocado',
    href: '/demos/skill-check',
  },
  {
    slug: 'reply-in-thread',
    title: 'Reply in Thread · micro-guide',
    company: 'Adoption · Slack & Teams',
    blurb: 'A 60-second click-through for Slack and Teams that teaches one habit: reply in the thread, not a new message. Plus a drop-in reminder GIF for the channel.',
    tag: 'Click-through + GIF',
    color: 'avocado',
    href: '/demos/reply-in-thread',
  },
  {
    slug: 'manager-coach',
    title: 'ManagerCoach Deep Dive',
    company: 'L&D Tool Concept',
    blurb: 'Managers discover their leadership style through card swipes and scenario choices, then get a personalized meeting agenda and script.',
    tag: 'AI coachbot',
    color: 'mustard',
    href: '/demos/manager-coach',
  },
  {
    slug: 'meridian-scenario',
    title: 'Compliance Scenario · Adverse Action',
    company: 'Meridian Financial',
    blurb: 'A single branching moment from the Reg B chapter. Decision first, feedback second: the pattern that powered the full course.',
    tag: 'Rise-style scenario',
    color: 'terracotta',
    href: '/demos/meridian-scenario',
  },
  {
    slug: 'ehr-simulator',
    title: 'EHR Simulator · ED Admission',
    company: 'Crestline Health',
    blurb: 'A five-step ED admission flow with a branching drug-allergy decision. Plain HTML/CSS/JS.',
    tag: 'Code-built sim',
    color: 'avocado',
    href: '/demos/ehr-simulator',
  },
  {
    slug: 'basecamp-facilitator',
    title: 'Facilitator Guide + Job Aid',
    company: 'Basecamp Retail',
    blurb: 'A representative spread from the 28-page facilitator guide, plus the double-sided pocket job aid it connects to.',
    tag: 'Print + blended',
    color: 'mustard',
    href: '/demos/basecamp-facilitator',
  },
];

const external = [
  {
    title: 'De-Escalation Soft Skills Training',
    company: 'Purple / Customer Care',
    blurb: 'A multi-part Rise course built to cut escalated transfers, using scenario practice across short microlearning segments.',
    tag: 'Rise 360 · published',
    color: 'terracotta',
    href: 'https://rise.articulate.com/share/A1E-L14GDapzilYYY7ZqTSySyFrjSNo7',
  },
  {
    title: 'Selling Purple Mattresses',
    company: 'Purple / Wholesale',
    blurb: 'Sales enablement for wholesale partners: closes the key knowledge gaps in B2B mattress sales without padding the learner\'s time.',
    tag: 'Rise 360 · published',
    color: 'mustard',
    href: 'https://rise.articulate.com/share/BGBwMTQOWH1Pm_yojY-ZvBI-DBFDfszr',
  },
  {
    title: 'Mattress Building Activity',
    company: 'Purple / Product Training',
    blurb: 'An interactive layered-build tool so new employees can speak confidently about each mattress component. Scored and replayable.',
    tag: 'Storyline · published',
    color: 'avocado',
    href: 'https://360.articulate.com/review/content/49bf4a26-4299-40bc-9141-a8ae0c7d2479/review',
  },
  {
    title: 'Zendesk Sell Simulator',
    company: 'Purple / Sales Systems',
    blurb: 'An interactive walkthrough inside Zendesk Sell. Learners practice capturing leads in the real software UI, not a disconnected demo.',
    tag: 'Storyline · published',
    color: 'terracotta',
    href: 'https://360.articulate.com/review/content/79b002cd-cbd8-472a-81eb-93bc84e4642f/review',
  },
];

const planned: typeof available = [];

const theme: Record<string, { tag: string; ring: string; initialsBg: string; initialsText: string }> = {
  terracotta: {
    tag: 'bg-primary-100 text-primary-700 border-primary-200',
    ring: 'from-primary-100/60 to-cream-50',
    initialsBg: 'bg-primary-100 text-primary-700 border-primary-200',
    initialsText: 'text-primary-700',
  },
  avocado: {
    tag: 'bg-secondary-100 text-secondary-700 border-secondary-200',
    ring: 'from-secondary-100/60 to-cream-50',
    initialsBg: 'bg-secondary-100 text-secondary-700 border-secondary-200',
    initialsText: 'text-secondary-700',
  },
  mustard: {
    tag: 'bg-accent-400/25 text-accent-700 border-accent-500/40',
    ring: 'from-accent-400/25 to-cream-50',
    initialsBg: 'bg-accent-400/25 text-accent-700 border-accent-500/40',
    initialsText: 'text-accent-700',
  },
};
---
<BaseLayout
  title="Live Demos"
  description="Shipped client courses plus code-built concept demos: simulations, branching scenarios, and AI roleplay."
>
  <section class="bg-cream-50 border-b-2 border-cocoa/15">
    <div class="relative max-w-4xl mx-auto px-6 py-14 sm:py-20 text-center">
      <h1 class="font-display font-semibold text-4xl sm:text-5xl text-cocoa tracking-tight">
        Live <span class="italic text-primary-600">demos</span>
      </h1>
      <p class="mt-5 text-lg text-cocoa/70 max-w-2xl mx-auto">
        Shipped client courses first, then concept builds I made to push past what authoring tools allow.
      </p>
    </div>
  </section>


  <!-- Published client work (real, leads the page) -->
  <section class="bg-cream-50 py-16 sm:py-20 border-t border-cocoa/10">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-8">
        <p class="font-display text-sm uppercase tracking-widest text-cocoa/50 mb-2">Published client work</p>
        <p class="text-cocoa/65 max-w-xl">Shipped Rise and Storyline courses from client projects, hosted on Articulate.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {external.map((d) => {
          const t = theme[d.color] ?? theme.terracotta;
          return (
            <a
              href={d.href}
              target="_blank"
              rel="noopener noreferrer"
              class={`group relative flex flex-col rounded-2xl border border-cocoa/15 bg-paper p-6 hover:border-primary-400 hover:shadow-lg hover:shadow-primary-600/10 transition-all`}
            >
              <span class={`inline-block self-start px-2.5 py-1 rounded-full text-xs font-semibold border ${t.tag}`}>
                {d.tag}
              </span>
              <p class="mt-5 text-xs font-semibold text-cocoa/50">{d.company}</p>
              <h2 class="mt-1 font-display font-semibold text-lg text-cocoa leading-snug">
                {d.title}
              </h2>
              <p class="mt-2 text-cocoa/65 leading-relaxed text-sm flex-1">
                {d.blurb}
              </p>
              <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-primary-600 group-hover:gap-2 transition-all">
                Open course
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Concept builds & interactive demos -->
  <section class="bg-paper py-16 sm:py-20 border-t border-cocoa/10">
    <div class="max-w-6xl mx-auto px-6">
      <div class="mb-8">
        <p class="font-display text-sm uppercase tracking-widest text-cocoa/50 mb-2">Concept builds &amp; interactive demos</p>
        <p class="text-cocoa/65 max-w-xl">Prototype pieces I built to show the methodology and the tech. The AI demos run against a live model when one is connected. Poke at them, take a wrong turn, restart.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {available.map((d) => {
          const t = theme[d.color] ?? theme.terracotta;
          return (
            <a
              href={d.href}
              class={`group relative block rounded-3xl border border-cocoa/15 bg-cream-50 p-6 sm:p-7 hover:border-primary-400 hover:shadow-xl hover:shadow-primary-600/10 transition-all`}
            >
              <div class={`absolute inset-x-0 top-0 h-24 rounded-t-3xl bg-gradient-to-b ${t.ring} opacity-70 pointer-events-none`}></div>
              <div class="relative">
                <span class={`inline-block px-2.5 py-1 rounded-full text-xs font-semibold border ${t.tag}`}>
                  {d.tag}
                </span>
                <p class="mt-5 text-sm font-semibold text-cocoa/60">{d.company}</p>
                <h2 class="mt-1 font-display font-semibold text-xl text-cocoa leading-tight">
                  {d.title}
                </h2>
                <p class="mt-3 text-cocoa/70 leading-relaxed text-sm">
                  {d.blurb}
                </p>
                <span class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-primary-600 group-hover:gap-2 transition-all">
                  Launch demo
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  {planned.length > 0 && (
    <section class="bg-cream-50 py-16 sm:py-20 border-t border-cocoa/10">
      <div class="max-w-6xl mx-auto px-6">
        <p class="font-display text-sm uppercase tracking-widest text-cocoa/50 mb-4">In progress</p>
        <div class="grid sm:grid-cols-2 gap-6">
          {planned.map((d) => {
            const t = theme[d.color] ?? theme.terracotta;
            return (
              <div class="rounded-3xl border border-dashed border-cocoa/20 bg-paper p-6 sm:p-7">
                <span class={`inline-block px-2.5 py-1 rounded-full text-xs font-semibold border ${t.tag}`}>
                  {d.tag}
                </span>
                <p class="mt-5 text-sm font-semibold text-cocoa/60">{d.company}</p>
                <h2 class="mt-1 font-display font-semibold text-xl text-cocoa leading-tight">
                  {d.title}
                </h2>
                <p class="mt-3 text-cocoa/70 leading-relaxed text-sm">
                  {d.blurb}
                </p>
                <span class="mt-6 inline-block text-sm font-semibold text-cocoa/50">
                  Coming soon
                </span>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
