---
import DeepDive from '../../components/ManagerCoach/DeepDive';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ManagerCoach · Deep Dive</title>
  <meta name="description" content="An AI-powered coaching tool that helps new managers discover their management style and build a personalised meeting plan." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bagel+Fat+One&family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=Space+Mono:wght@400;700&family=Caveat:wght@400;700&display=swap" rel="stylesheet" />
  <style is:global>
    /* ── Design tokens — dark green default ── */
    :root {
      --paper:       #141414;
      --paper-2:     #0d0d0d;
      --ink:         #F2E9D6;
      --ink-2:       #D6C7AB;
      --ink-3:       #999999;
      --line:        #262626;
      --line-2:      #333333;
      --ph:          #1f1f1f;
      --ph-2:        #1a1a1a;
      --canvas-bg:   #0a0a0a;
      --mustard:     #E8B752;
      --terracotta:  #D87854;
      --avocado:     #9DB35E;
      --plum:        #B26C84;
      --teal:        #67A6A8;
      --sky:         #B7D3D2;
      --dark-fixed:  #211712;
      --cream-fixed: #F2E9D6;
      --shadow:      8px 10px 0 rgba(0,0,0,0.45);
      --shadow-soft: 0 6px 20px rgba(0,0,0,0.35);
      --r-sm: 8px; --r-md: 14px; --r-lg: 22px; --r-xl: 999px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      overflow: hidden;
      background: var(--canvas-bg);
      color: var(--ink);
      font-family: 'DM Sans', system-ui, sans-serif;
      color-scheme: dark;
    }

    /* Astro wraps client:only components in astro-island — make it fill + center */
    astro-island {
      display: flex;
      width: 100vw;
      height: 100vh;
      align-items: center;
      justify-content: center;
      background: var(--canvas-bg);
    }

    /* ── Typography ── */
    .display {
      font-family: 'Bagel Fat One', serif;
      letter-spacing: -0.01em;
      line-height: 0.95;
      font-weight: 400;
    }

    /* ── Primitives ── */
    .ph {
      background: var(--ph);
      border-radius: var(--r-md);
      display: flex; align-items: center; justify-content: center;
      color: var(--ink-3); font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em;
    }
    .line { height: 10px; background: var(--ph); border-radius: var(--r-xl); }
    .line.short { width: 40%; } .line.med { width: 65%; } .line.long { width: 85%; }

    .pill {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 6px 14px; border-radius: var(--r-xl);
      border: 1.5px solid var(--ink); background: var(--paper);
      font-size: 12px; font-weight: 500; white-space: nowrap; cursor: default;
    }
    .pill.solid     { background: var(--ink); color: var(--paper); border-color: var(--ink); }
    .pill.mustard   { background: var(--mustard);    border-color: var(--ink); color: var(--dark-fixed); }
    .pill.terracotta{ background: var(--terracotta); border-color: var(--ink); color: var(--cream-fixed); }
    .pill.avocado   { background: var(--avocado);    border-color: var(--ink); color: var(--cream-fixed); }
    .pill.teal      { background: var(--teal);       border-color: var(--ink); color: var(--cream-fixed); }
    .pill.plum      { background: var(--plum);       border-color: var(--ink); color: var(--cream-fixed); }
    .pill.sky       { background: var(--sky);        border-color: var(--ink); color: var(--dark-fixed); }
    .pill.ghost     { background: transparent; border-color: var(--line-2); color: var(--ink-2); }

    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 10px;
      padding: 12px 22px; border-radius: var(--r-xl); border: 2px solid var(--ink);
      background: var(--paper); font-size: 14px; font-weight: 600; font-family: inherit;
      color: var(--ink); cursor: pointer; transition: opacity 0.15s, transform 0.12s;
    }
    .btn:hover { opacity: 0.88; }
    .btn:active { transform: scale(0.97); }
    .btn.primary    { background: var(--ink); color: var(--paper); }
    .btn.mustard    { background: var(--mustard); color: var(--dark-fixed); }
    .btn.terracotta { background: var(--terracotta); color: var(--cream-fixed); }
    .btn.ghost      { background: transparent; border-color: var(--line-2); color: var(--ink-2); }
    .btn.big        { padding: 16px 28px; font-size: 16px; }
    .btn:disabled   { opacity: 0.4; cursor: not-allowed; }
    .btn:focus-visible { outline: 3px solid var(--mustard); outline-offset: 2px; }

    .card {
      background: var(--paper); border: 1.5px solid var(--line-2);
      border-radius: var(--r-lg); padding: 22px; color: var(--ink);
    }
    .card.solid-ink   { background: var(--ink);  color: var(--paper); border-color: var(--ink); }
    .card.mustard     { background: var(--mustard);    border-color: var(--ink); color: var(--dark-fixed); }
    .card.terracotta  { background: var(--terracotta); border-color: var(--ink); color: var(--cream-fixed); }
    .card.avocado     { background: var(--avocado);    border-color: var(--ink); color: var(--cream-fixed); }
    .card.teal        { background: var(--teal);       border-color: var(--ink); color: var(--cream-fixed); }
    .card.sky         { background: var(--sky);        border-color: var(--ink); color: var(--dark-fixed); }

    .tag {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 3px 10px; font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; border-radius: var(--r-xl);
      background: var(--paper-2); color: var(--ink-2); border: 1px solid var(--line);
    }
    .tag.solid { background: var(--ink); color: var(--paper); border-color: var(--ink); }

    .stamp {
      display: inline-flex; align-items: center; justify-content: center;
      padding: 3px 10px; border: 2px dashed var(--ink); border-radius: 4px;
      font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
      transform: rotate(-3deg); background: var(--paper); color: var(--ink);
    }

    /* Sun / starburst */
    .sun {
      width: 56px; height: 56px; border-radius: 50%; background: var(--mustard);
      position: relative; flex: none;
    }
    .sun::before {
      content: ""; position: absolute; inset: -10px; border-radius: 50%;
      background: conic-gradient(from 0deg,
        var(--mustard) 0 18deg, transparent 18deg 30deg,
        var(--mustard) 30deg 48deg, transparent 48deg 60deg,
        var(--mustard) 60deg 78deg, transparent 78deg 90deg,
        var(--mustard) 90deg 108deg, transparent 108deg 120deg,
        var(--mustard) 120deg 138deg, transparent 138deg 150deg,
        var(--mustard) 150deg 168deg, transparent 168deg 180deg,
        var(--mustard) 180deg 198deg, transparent 198deg 210deg,
        var(--mustard) 210deg 228deg, transparent 228deg 240deg,
        var(--mustard) 240deg 258deg, transparent 258deg 270deg,
        var(--mustard) 270deg 288deg, transparent 288deg 300deg,
        var(--mustard) 300deg 318deg, transparent 318deg 330deg,
        var(--mustard) 330deg 348deg, transparent 348deg 360deg);
      -webkit-mask: radial-gradient(circle, transparent 26px, #000 26px, #000 36px, transparent 36px);
              mask: radial-gradient(circle, transparent 26px, #000 26px, #000 36px, transparent 36px);
      z-index: 0;
    }
    .sun > * { position: relative; z-index: 1; }

    /* Wavy divider */
    .wave {
      height: 14px;
      background: radial-gradient(circle at 7px 14px, transparent 7px, var(--ink) 7px 8.5px, transparent 8.5px) 0 0/14px 14px repeat-x;
      opacity: 0.5;
    }

    /* Bubble */
    .bubble {
      background: var(--ink); color: var(--paper); border-radius: var(--r-lg);
      padding: 14px 18px; font-size: 13px; line-height: 1.45; max-width: 380px; position: relative;
    }
    .bubble::after {
      content: ""; position: absolute; left: 28px; bottom: -7px;
      width: 14px; height: 14px; background: var(--ink); transform: rotate(45deg); border-radius: 2px;
    }

    /* Checklist */
    .check { display: flex; gap: 12px; align-items: flex-start; }
    .check-box {
      flex: none; width: 22px; height: 22px; border-radius: 6px;
      border: 2px solid var(--ink); background: var(--paper);
    }
    .check-box.done { background: var(--avocado); }
    .check-box.done::after { content: "✓"; color: var(--cream-fixed); font-weight: 700; display: block; text-align: center; font-size: 14px; line-height: 18px; }

    /* Brand mark */
    .brand-mark {
      width: 32px; height: 32px; border-radius: 50%; background: var(--terracotta);
      position: relative; display: inline-flex; align-items: center; justify-content: center;
    }
    .brand-mark::after {
      content: ""; position: absolute; inset: 6px; border-radius: 50%; background: var(--mustard);
    }
    .brand-name { font-family: 'Bagel Fat One', serif; font-size: 18px; letter-spacing: 0.02em; }

    /* ── Deep Dive App ── */
    .dd-app {
      width: 100%; max-width: 1280px; height: min(840px, 96vh);
      background: var(--paper); border-radius: 20px;
      box-shadow: 0 30px 80px rgba(0,0,0,0.5), 0 0 0 1px var(--line);
      overflow: hidden; display: flex; flex-direction: column; position: relative;
    }

    /* Top bar */
    .dd-topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 28px; border-bottom: 1.5px solid var(--line);
      background: var(--paper-2); flex: none;
    }
    .dd-topbar-left { display: flex; align-items: center; gap: 14px; font-size: 13px; white-space: nowrap; flex: none; }
    .dd-chapters { display: flex; gap: 6px; align-items: center; }
    .dd-chip {
      font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--ink-3); padding: 4px 10px; border-radius: 999px; border: 1px solid var(--line);
    }
    .dd-chip.on  { color: var(--paper); border-color: var(--ink); background: var(--ink); }
    .dd-chip.done{ color: var(--avocado); border-color: var(--avocado); }

    .dd-progress {
      flex: 1; height: 6px; border-radius: 999px; background: var(--ph);
      margin: 0 22px; overflow: hidden; position: relative;
    }
    .dd-progress-fill {
      height: 100%; background: linear-gradient(90deg, var(--mustard), var(--terracotta));
      transition: width 0.5s cubic-bezier(0.2, 0.7, 0.3, 1);
    }

    /* Stage */
    .dd-stage { flex: 1; position: relative; overflow: hidden; }
    .dd-scene {
      position: absolute; inset: 0; overflow: auto;
      animation: scene-in 400ms cubic-bezier(0.2, 0.7, 0.3, 1) both;
    }
    @keyframes scene-in  { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes scene-out { from { opacity: 1; transform: translateY(0); }   to { opacity: 0; transform: translateY(-14px); } }

    /* Welcome */
    .dd-welcome {
      height: 100%; display: grid; grid-template-columns: 1.05fr 0.95fr;
      align-items: center; padding: 0 80px; gap: 60px;
    }
    .dd-welcome .display { font-size: 76px; line-height: 0.9; margin: 12px 0 18px; }
    .dd-welcome .display em { font-style: normal; color: var(--terracotta); }
    .dd-name-input {
      display: flex; align-items: center; gap: 12px;
      padding: 14px 18px; border: 2px solid var(--ink); border-radius: 999px;
      background: var(--paper-2); max-width: 480px; margin-top: 22px;
    }
    .dd-name-input label { font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); white-space: nowrap; }
    .dd-name-input input { flex: 1; background: transparent; border: 0; outline: 0; font: inherit; font-size: 18px; color: var(--ink); }
    .dd-welcome-tiles { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .dd-welcome-tile {
      border: 2px solid var(--ink); border-radius: 22px; padding: 22px;
      min-height: 170px; display: flex; flex-direction: column; justify-content: space-between;
      position: relative; overflow: hidden;
    }
    .dd-welcome-tile .label { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.7; }
    .dd-welcome-tile .display { font-size: 26px; line-height: 0.95; margin: 0; }

    /* Context */
    .dd-context {
      height: 100%; display: grid; grid-template-columns: 0.7fr 1.3fr;
      padding: 48px 70px; gap: 56px; align-items: center;
    }
    .dd-context-q .display { font-size: 48px; line-height: 0.95; margin: 12px 0 14px; }
    .dd-context-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .dd-pick {
      border: 1.5px solid var(--line-2); background: var(--paper); border-radius: 18px;
      padding: 18px; min-height: 140px; display: flex; flex-direction: column; gap: 6px;
      cursor: pointer; transition: transform 0.18s, border-color 0.18s, background 0.18s;
      text-align: left; font: inherit; color: var(--ink); position: relative;
    }
    .dd-pick:hover { transform: translateY(-2px); border-color: var(--ink); }
    .dd-pick.on { background: var(--mustard); border-color: var(--ink); border-width: 2px; color: var(--dark-fixed); }
    .dd-pick .big  { font-family: 'Bagel Fat One', serif; font-size: 36px; line-height: 1; }
    .dd-pick .head { font-size: 14px; font-weight: 700; }
    .dd-pick .sub  { font-size: 12px; color: var(--ink-2); }
    .dd-pick.on .sub { color: var(--dark-fixed); opacity: 0.7; }
    .dd-chapter-rail { margin-top: 32px; display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
    .dd-rail-item {
      padding: 10px 14px; border: 1.5px solid var(--line); border-radius: 14px;
      background: var(--paper-2); font-size: 12px; opacity: 0.55;
      transition: opacity 0.18s, background 0.18s, border-color 0.18s;
    }
    .dd-rail-item.done   { opacity: 1; background: var(--paper); border-color: var(--avocado); }
    .dd-rail-item.active { opacity: 1; border-color: var(--ink); }
    .dd-rail-item .k { font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-3); }
    .dd-rail-item .v { font-weight: 600; margin-top: 2px; }

    /* Swipe */
    .dd-swipe {
      height: 100%; display: grid; grid-template-columns: 1fr 440px 1fr;
      padding: 36px 60px; gap: 40px; align-items: center; justify-items: center;
    }
    .dd-swipe-side { display: flex; flex-direction: column; gap: 10px; width: 100%; max-width: 220px; }
    .dd-swipe-side.right { align-items: flex-start; text-align: left; }
    .dd-swipe-side.left  { align-items: flex-end;   text-align: right; }
    .dd-arrow {
      width: 90px; height: 90px; border-radius: 50%; border: 2px solid var(--ink);
      background: var(--paper); font-family: inherit; font-size: 28px; cursor: pointer;
      color: var(--ink); transition: transform 0.15s, background 0.18s;
      display: flex; align-items: center; justify-content: center;
    }
    .dd-swipe-side.left  .dd-arrow { background: var(--mustard); color: var(--dark-fixed); }
    .dd-swipe-side.right .dd-arrow { background: var(--avocado); color: var(--cream-fixed); }
    .dd-arrow:hover  { transform: scale(1.06); }
    .dd-arrow:active { transform: scale(0.94); }

    .dd-card-stage  { position: relative; height: 280px; width: 100%; user-select: none; }
    .dd-swipe-card {
      position: absolute; inset: 0; border: 2px solid var(--ink); border-radius: 22px;
      background: var(--paper); padding: 26px 28px; display: flex; flex-direction: column;
      cursor: grab; transition: transform 0.18s cubic-bezier(0.2,0.7,0.3,1), opacity 0.18s;
      will-change: transform; box-shadow: 0 12px 40px rgba(0,0,0,0.25);
    }
    .dd-swipe-card .dd-card-head { margin-bottom: 18px; }
    .dd-swipe-card .dd-card-q   { margin-bottom: 24px; }
    .dd-swipe-card.dragging      { cursor: grabbing; transition: none; }
    .dd-swipe-card.flying-left  { transform: translateX(-140%) rotate(-22deg) !important; opacity: 0; }
    .dd-swipe-card.flying-right { transform: translateX( 140%) rotate( 22deg) !important; opacity: 0; }
    .dd-swipe-card.behind-1 { transform: translate(0, 14px) scale(0.96); opacity: 0.6; pointer-events: none; }
    .dd-swipe-card.behind-2 { transform: translate(0, 28px) scale(0.92); opacity: 0.3; pointer-events: none; }

    .dd-card-head    { display: flex; justify-content: space-between; align-items: center; }
    .dd-card-q       { font-family: 'Bagel Fat One', serif; font-size: 28px; line-height: 1.05; }
    .dd-card-options { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .dd-card-option {
      padding: 18px 14px; border: 2px solid var(--ink); border-radius: 16px;
      font-weight: 600; text-align: center; cursor: pointer;
      transition: transform 0.12s; font: inherit; font-size: 14px; font-weight: 600;
    }
    .dd-card-option:hover { transform: translateY(-1px); }
    .dd-card-option.a { background: var(--mustard);  color: var(--dark-fixed); }
    .dd-card-option.b { background: var(--avocado);  color: var(--cream-fixed); }

    .dd-swipe-meter { display: flex; flex-direction: column; gap: 12px; }
    .dd-swipe-meter .head { font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 4px; }
    .dd-meter {
      height: 14px; background: var(--ph); border-radius: 999px; border: 1.5px solid var(--ink);
      position: relative; overflow: hidden;
    }
    .dd-meter-fill {
      position: absolute; left: 0; top: 0; bottom: 0; width: var(--v, 50%);
      background: var(--terracotta); border-radius: 999px;
      transition: width 0.5s cubic-bezier(0.2,0.7,0.3,1);
    }

    .dd-card-dots { display: flex; gap: 6px; justify-content: center; margin-top: 18px; }
    .dd-card-dot  { width: 8px; height: 8px; border-radius: 999px; background: var(--ph); border: 1px solid var(--ink); transition: width 0.18s, background 0.18s; }
    .dd-card-dot.done { background: var(--avocado); }
    .dd-card-dot.cur  { background: var(--terracotta); width: 26px; }

    /* Scenario */
    .dd-scenario {
      height: 100%; display: grid; grid-template-columns: 1.1fr 0.9fr;
      padding: 32px 70px; gap: 48px; align-items: center;
    }
    .dd-film { border: 2px solid var(--ink); border-radius: 18px; overflow: hidden; background: var(--ink); color: var(--paper); box-shadow: 0 16px 50px rgba(0,0,0,0.4); }
    .dd-film-head { padding: 10px 14px; display: flex; justify-content: space-between; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; }
    .dd-film-frame {
      height: 260px; background: linear-gradient(135deg, #1B130D 0%, var(--plum) 100%);
      position: relative; display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 8px;
    }
    .dd-film-frame .display { font-size: 36px; color: var(--paper); margin: 0; }
    .dd-film-frame .stamp   { position: absolute; top: 14px; right: 14px; background: var(--mustard); color: var(--dark-fixed); border-color: var(--dark-fixed); }
    .dd-film-body { padding: 20px 22px 24px; }
    .dd-film-body .who  { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; opacity: 0.7; margin-bottom: 6px; }
    .dd-film-body .what { font-size: 17px; line-height: 1.45; }

    .dd-choice {
      display: flex; align-items: center; gap: 14px; padding: 14px;
      border: 1.5px solid var(--ink); border-radius: 16px; background: var(--paper);
      cursor: pointer; transition: transform 0.15s, background 0.15s;
      text-align: left; font: inherit; color: var(--ink); width: 100%;
    }
    .dd-choice:hover { transform: translateX(4px); background: var(--paper-2); }
    .dd-choice .badge {
      width: 38px; height: 38px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Bagel Fat One', serif; font-size: 18px; border: 2px solid var(--ink); flex: none;
    }
    .dd-choice .body { flex: 1; }
    .dd-choice .body .h { font-weight: 700; font-size: 14px; }
    .dd-choice .body .s { font-size: 12px; color: var(--ink-2); margin-top: 2px; }
    .dd-choice .arr { color: var(--ink-3); font-size: 18px; }

    /* Processing */
    .dd-process {
      height: 100%; display: grid; grid-template-columns: 1fr 1fr;
      padding: 44px 80px; gap: 56px; align-items: center;
    }
    .dd-checklist .row {
      display: grid; grid-template-columns: 16px 1fr auto; gap: 12px;
      align-items: center; padding: 10px 0; border-bottom: 1px dashed var(--line); font-size: 14px;
    }
    .dd-checklist .row .pip { width: 14px; height: 14px; border-radius: 50%; border: 1.5px solid var(--ink); background: var(--ph); }
    .dd-checklist .row.done   .pip { background: var(--avocado); }
    .dd-checklist .row.active .pip { background: var(--terracotta); animation: pulse 1.2s infinite; }
    .dd-checklist .row.queue { color: var(--ink-3); }
    .dd-checklist .row .v { font-size: 12px; color: var(--ink-3); font-family: 'Space Mono', monospace; }
    @keyframes pulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.3); } }

    .dd-portrait-card { border: 2px solid var(--ink); border-radius: 22px; padding: 26px; background: var(--paper-2); }
    .dd-portrait-card .display { font-size: 42px; line-height: 0.95; margin-top: 4px; }

    .dd-coach-msg {
      background: var(--terracotta); color: var(--cream-fixed); padding: 14px 18px;
      border-radius: 18px; font-size: 13px; line-height: 1.45; margin-top: 14px;
      animation: scene-in 600ms;
    }

    /* Output / Deck */
    .dd-output { height: 100%; display: grid; grid-template-columns: 220px 1fr 320px; }
    .dd-out-side {
      background: var(--paper-2); border-right: 1.5px solid var(--line);
      padding: 22px 14px; display: flex; flex-direction: column; gap: 6px; overflow-y: auto;
    }
    .dd-out-side .head { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); padding: 0 8px; margin-bottom: 6px; }
    .dd-out-row {
      display: flex; gap: 8px; align-items: center; padding: 8px 10px; border-radius: 10px;
      font-size: 12px; color: var(--ink-2); cursor: pointer; text-align: left; font: inherit;
      background: transparent; border: 0;
    }
    .dd-out-row .n { font-family: 'Space Mono', monospace; opacity: 0.6; width: 18px; }
    .dd-out-row.on { background: var(--ink); color: var(--paper); }
    .dd-out-row:not(.on):hover { background: var(--paper); color: var(--ink); }

    .dd-out-main { padding: 18px 28px; display: flex; flex-direction: column; gap: 14px; overflow: hidden; }
    .dd-slide {
      flex: 1; border: 2px solid var(--ink); border-radius: 14px;
      padding: 44px 52px; position: relative; display: flex;
      flex-direction: column; justify-content: center; overflow: hidden;
    }
    .dd-slide.theme-mustard    { background: var(--mustard);    color: var(--dark-fixed); }
    .dd-slide.theme-terracotta { background: var(--terracotta); color: var(--cream-fixed); }
    .dd-slide.theme-avocado    { background: var(--avocado);    color: var(--cream-fixed); }
    .dd-slide.theme-teal       { background: var(--teal);       color: var(--cream-fixed); }
    .dd-slide.theme-paper      { background: var(--paper);      color: var(--ink); }
    .dd-slide.theme-ink        { background: var(--ink);        color: var(--paper); }
    .dd-slide .meta  { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; position: absolute; bottom: 18px; left: 52px; opacity: 0.7; }
    .dd-slide .title { font-family: 'Bagel Fat One', serif; font-size: 76px; line-height: 0.9; margin: 0; }
    .dd-slide .body  { font-size: 20px; margin-top: 14px; line-height: 1.35; max-width: 660px; }

    .dd-slide-strip { display: flex; gap: 8px; }
    .dd-slide-strip button {
      flex: 1; aspect-ratio: 16/9; border-radius: 6px; border: 1px solid var(--line);
      cursor: pointer; font: inherit; font-family: 'Space Mono', monospace; font-size: 10px;
      color: var(--ink-3); display: flex; align-items: center; justify-content: center;
      background: var(--paper-2);
    }
    .dd-slide-strip button.on { border: 2px solid var(--ink); color: var(--ink); }

    .dd-out-rail {
      background: var(--paper-2); border-left: 1.5px solid var(--line);
      padding: 22px; display: flex; flex-direction: column; gap: 14px; overflow-y: auto;
    }
    .dd-notes { background: var(--ink); color: var(--paper); padding: 14px 16px; border-radius: 14px; font-size: 13px; line-height: 1.5; }
    .dd-notes .label {
      background: var(--mustard); color: var(--dark-fixed); font-size: 10px; font-weight: 700;
      letter-spacing: 0.12em; padding: 2px 8px; border-radius: 999px; display: inline-block; margin-bottom: 8px;
    }

    .dd-ifthen-row { border: 1.5px solid var(--line-2); border-radius: 14px; padding: 12px; font-size: 12px; background: var(--paper); }
    .dd-ifthen-row .pill { font-size: 10px; margin-right: 6px; }
    .dd-ifthen-row .then { color: var(--ink-2); font-style: italic; margin-top: 6px; padding-top: 6px; border-top: 1px dashed var(--line); }

    /* Actions row */
    .dd-actions { display: flex; justify-content: space-between; align-items: center; gap: 12px; }

    /* Loading dots */
    .dd-typing { display: inline-flex; gap: 4px; align-items: center; }
    .dd-typing i { width: 6px; height: 6px; background: currentColor; border-radius: 50%; animation: typing 1.2s infinite; display: inline-block; }
    .dd-typing i:nth-child(2) { animation-delay: 0.15s; }
    .dd-typing i:nth-child(3) { animation-delay: 0.30s; }
    @keyframes typing {
      0%, 60%, 100% { opacity: 0.3; transform: translateY(0); }
      30% { opacity: 1; transform: translateY(-3px); }
    }

    /* input base */
    input { background: var(--paper); color: var(--ink); }
    input::placeholder { color: var(--ink-3); }
    input:focus-visible { outline: 3px solid var(--mustard); outline-offset: 2px; }

    /* ── Mobile ── */
    @media (max-width: 640px) {
      html, body { overflow-y: auto; height: auto; }

      astro-island {
        height: auto;
        min-height: 100dvh;
        align-items: flex-start;
      }

      .dd-app {
        border-radius: 0;
        box-shadow: none;
        height: auto;
        min-height: 100dvh;
        width: 100vw;
        max-width: 100vw;
      }

      .dd-topbar { padding: 10px 14px; }
      .dd-topbar-left { gap: 8px; font-size: 11px; }
      .dd-chapters { display: none; }
      .dd-progress { margin: 0 10px; }

      /* Allow scenes to scroll naturally */
      .dd-stage { position: relative; overflow-y: auto; height: auto; flex: 1 0 auto; }
      .dd-scene { position: relative; inset: auto; overflow: visible; }

      /* ── Welcome ── */
      .dd-welcome {
        grid-template-columns: 1fr;
        padding: 22px 18px 32px;
        gap: 22px;
        height: auto;
      }
      .dd-welcome .display { font-size: 46px !important; }
      .dd-name-input { max-width: 100%; margin-top: 16px; }
      .dd-welcome-tiles { grid-template-columns: 1fr 1fr; gap: 8px; }
      .dd-welcome-tile { min-height: 100px; padding: 14px; }
      .dd-welcome-tile .display { font-size: 16px; }
      .dd-welcome-tile .label { font-size: 9px; }

      /* ── Context ── */
      .dd-context {
        grid-template-columns: 1fr;
        padding: 18px 16px 28px;
        gap: 18px;
        height: auto;
      }
      .dd-context-q .display { font-size: 28px; }
      .dd-context-grid { grid-template-columns: 1fr 1fr; gap: 8px; }
      .dd-pick { min-height: 90px; padding: 10px 12px; }
      .dd-pick .big { font-size: 24px; }
      .dd-pick .head { font-size: 11px; }
      .dd-pick .sub { font-size: 10px; }
      .dd-chapter-rail { grid-template-columns: repeat(3, 1fr); gap: 5px; margin-top: 14px; }
      .dd-rail-item { padding: 8px 10px; font-size: 11px; }
      .dd-rail-item .k { font-size: 9px; }

      /* ── Swipe ── */
      .dd-swipe {
        display: flex;
        flex-direction: column;
        padding: 14px 16px 20px;
        gap: 14px;
        height: auto;
        align-items: stretch;
      }
      /* Left arrow side: goes below the card */
      .dd-swipe-side {
        order: 2;
        flex-direction: row;
        width: 100%;
        max-width: 100%;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
      }
      .dd-swipe-side.left { order: 2; align-items: center; }
      .dd-swipe-side.right { order: 3; flex-direction: row-reverse; align-items: center; }
      /* Hide text labels — keep just the arrows */
      .dd-swipe-side > div:not(.dd-arrow) { display: none; }
      .dd-swipe-side > div[style] { display: none !important; }
      .dd-arrow { width: 52px; height: 52px; font-size: 20px; }
      /* Show both arrow sides as one row below card */
      .dd-swipe > div:nth-child(2) { order: 1; width: 100%; }

      .dd-card-stage { height: 210px; }
      .dd-swipe-card { padding: 14px 16px; }
      .dd-card-q { font-size: 19px; }
      .dd-card-options { gap: 8px; }
      .dd-card-option { padding: 10px 6px; font-size: 12px; }
      .dd-swipe-meter { display: none; }
      .dd-card-dots { margin-top: 10px; }
      .dd-actions { flex-wrap: wrap; gap: 8px; justify-content: center; }

      /* ── Scenario ── */
      .dd-scenario {
        grid-template-columns: 1fr;
        padding: 16px 16px;
        gap: 14px;
        height: auto;
      }
      .dd-film-frame { height: 150px; }
      .dd-film-frame .display { font-size: 22px; }
      .dd-film-body { padding: 12px 14px 16px; }
      .dd-film-body .what { font-size: 13px; }
      .dd-choice { padding: 10px 10px; gap: 10px; }
      .dd-choice .badge { width: 30px; height: 30px; font-size: 13px; }
      .dd-choice .body .h { font-size: 12px; }
      .dd-choice .body .s { font-size: 11px; }

      /* ── Processing ── */
      .dd-process {
        grid-template-columns: 1fr;
        padding: 22px 16px;
        gap: 22px;
        height: auto;
      }
      .dd-portrait-card .display { font-size: 28px; }
      .dd-coach-msg { font-size: 12px; }

      /* ── Output ── */
      .dd-output {
        display: flex;
        flex-direction: column;
        height: auto;
      }
      /* Slide list → horizontal scrolling tab strip */
      .dd-out-side {
        border-right: none;
        border-bottom: 1.5px solid var(--line);
        flex-direction: row;
        flex-wrap: nowrap;
        overflow-x: auto;
        overflow-y: hidden;
        padding: 8px 12px;
        gap: 4px;
        -webkit-overflow-scrolling: touch;
      }
      .dd-out-side .head { display: none; }
      .dd-out-row {
        white-space: nowrap;
        border: 1px solid var(--line-2);
        border-radius: 20px;
        padding: 5px 10px;
        font-size: 11px;
      }
      .dd-out-main { padding: 12px; overflow: visible; }
      .dd-slide { padding: 22px 18px; min-height: 180px; }
      .dd-slide .title { font-size: 40px !important; }
      .dd-slide .body  { font-size: 15px !important; }
      .dd-slide .meta  { left: 18px; font-size: 9px; }
      .dd-slide-strip { display: none; }
      .dd-actions { padding: 0 2px; }
      /* Notes rail → stacked below */
      .dd-out-rail {
        border-left: none;
        border-top: 1.5px solid var(--line);
        padding: 14px;
        overflow: visible;
        gap: 10px;
      }
      .dd-notes { font-size: 12px; }
      .dd-ifthen-row { font-size: 11px; }
    }

    @media print {
      .dd-topbar, .dd-stage { display: none !important; }
    }
  </style>
</head>
<body>
  <DeepDive client:load />
</body>
</html>
