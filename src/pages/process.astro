---
import BaseLayout from '../layouts/BaseLayout.astro';
import MoonStar from '../components/decor/MoonStar.astro';
import Sparkles from '../components/decor/Sparkles.astro';

const phases = [
  {
    num: '01',
    short: 'Discover',
    title: 'Discovery & analysis',
    color: 'terracotta',
    pitch: 'Learn what the business actually needs before promising what training can deliver.',
    activities: [
      'Stakeholder interviews with sponsors, managers, and target learners',
      'Performance analysis: where exactly is the gap between what people do and what the business needs?',
      'Root-cause check: is this a knowledge problem, a skill problem, or a system problem?',
      'Success metrics agreed before any content decisions happen'
    ],
    outputs: [
      'A one-page problem statement signed off by the sponsor',
      'Baseline metrics (the numbers we\'re moving)',
      'Learner profile and context map',
      'Go/no-go recommendation; sometimes the answer is "this isn\'t a training problem"'
    ],
    heuristic: '"No training" is a legitimate recommendation. If it\'s a process problem, say so on page one. The sponsor will respect you for it later.'
  },
  {
    num: '02',
    short: 'Design',
    title: 'Design',
    color: 'avocado',
    pitch: 'Make the hard structural decisions on paper before a single screen gets built.',
    activities: [
      'Write measurable terminal objectives (Mager-style) tied to the business metrics',
      'Pick a modality against a checklist (classroom, blended, code-built, Rise, microlearning) using evidence, not taste',
      'Storyboard scenarios and branching with realistic detours, not only happy paths',
      'Design the assessment before the content: what would prove the objective was met?'
    ],
    outputs: [
      'Design document covering objectives, modality rationale, assessment strategy',
      'Scenario map with branching logic',
      'Rough wireframes or click-through sketches',
      'Risk list: what\'s most likely to break in build?'
    ],
    heuristic: 'The modality decision is where most projects fail. A "just make a Rise module" instinct is usually a design problem dressed as a tooling problem.'
  },
  {
    num: '03',
    short: 'Build',
    title: 'Development',
    color: 'mustard',
    pitch: 'Prototype early, iterate in small loops, and pick tools based on what the learner needs, not the department license.',
    activities: [
      'Prototype the highest-risk interaction first (the scenario engine, the simulator, the branching module), not the intro screen',
      'Rise 360 for linear rapid build; code-built HTML/CSS/JS when the interaction matters or data fidelity is required',
      'AI-assisted scaffolding in Cursor and Claude for code-built work, compressing weeks into days',
      'Two rounds of learner testing before handoff, cheaper than fixing it after launch'
    ],
    outputs: [
      'Working prototype of the riskiest piece, shown to stakeholders in week 2',
      'Production build against the agreed modality',
      'Accessibility audit (target: WCAG 2.1 AA)',
      'Facilitator and IT deployment notes'
    ],
    heuristic: 'If the first demo is a polished intro screen, you built the wrong thing first. Show the hardest part working, or don\'t show anything.'
  },
  {
    num: '04',
    short: 'Deliver',
    title: 'Delivery & change',
    color: 'terracotta',
    pitch: 'Treat the launch as a rollout project, not a file transfer.',
    activities: [
      'LMS or host deployment and smoke test',
      'Train-the-trainer where people facilitate, SME briefings where they don\'t',
      'Communications plan with managers, so people know why this exists and when they\'re expected to finish it',
      'Support channel for the first 30 days so early friction gets fixed fast'
    ],
    outputs: [
      'Deployed experience with access pathways verified',
      'Manager toolkit (email copy, talking points, completion tracking)',
      'Clear escalation path for issues in the first 30 days'
    ],
    heuristic: 'Managers are the single biggest variable in whether training sticks. Build for them, too.'
  },
  {
    num: '05',
    short: 'Measure',
    title: 'Evaluation',
    color: 'avocado',
    pitch: 'Prove the work landed by measuring against the metrics agreed in Discovery, not what\'s easy to count.',
    activities: [
      'Level 1, reaction: surveys, kept short and pointed',
      'Level 2, learning: xAPI statements from interactions, scenario outcomes, and assessments',
      'Level 3, behavior: change measured in the operational system (help desk tickets, error rates, cycle times)',
      'Level 4, results: tied back to the sponsor\'s business metric'
    ],
    outputs: [
      'xAPI statement schema and LRS pipeline (SCORM Cloud or client LRS)',
      'Dashboards for L&D + business partners',
      '30/60/90-day review of behavior-change data',
      'Lessons-learned doc to feed the next project'
    ],
    heuristic: 'Kirkpatrick 4 is where the story lives. If you can\'t connect the training to a business outcome, the next project will be a harder sell.'
  }
];

const colorMap: Record<string, { bg: string; border: string; num: string; tag: string }> = {
  terracotta: {
    bg: 'bg-primary-50',
    border: 'border-primary-200',
    num: 'text-primary-500',
    tag: 'bg-primary-100 text-primary-700 border-primary-200'
  },
  avocado: {
    bg: 'bg-secondary-100/50',
    border: 'border-secondary-200',
    num: 'text-secondary-600',
    tag: 'bg-secondary-100 text-secondary-700 border-secondary-200'
  },
  mustard: {
    bg: 'bg-accent-400/15',
    border: 'border-accent-500/30',
    num: 'text-accent-700',
    tag: 'bg-accent-400/25 text-accent-700 border-accent-500/40'
  }
};
---
<BaseLayout
  title="Process"
  description="The five-phase methodology behind every project: Discovery, Design, Development, Delivery, Evaluation."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-paper paper-bg">
    <MoonStar class="absolute top-10 left-6 sm:left-12 w-10 sm:w-14 h-auto opacity-90 hidden sm:block" />
    <Sparkles class="hidden md:block absolute bottom-10 right-10 w-28 lg:w-36 h-auto opacity-80 pointer-events-none" />

    <div class="relative max-w-4xl mx-auto px-6 py-20 sm:py-28">
      <p class="font-display text-sm uppercase tracking-widest text-cocoa/50 mb-3">How I work</p>
      <h1 class="font-display font-semibold text-cocoa text-4xl sm:text-5xl lg:text-6xl leading-tight tracking-tight">
        A five-phase <span class="italic text-primary-600">methodology</span>, tuned for AI-assisted L&amp;D.
      </h1>
      <p class="mt-6 text-lg text-cocoa/75 leading-relaxed max-w-3xl">
        Every project in the case studies uses the same framework. It borrows from ADDIE and Kirkpatrick and leans on Mager for objectives. What's new is the development phase: AI tooling makes hand-built interactions and client-grade data pipelines practical on a small-team budget.
      </p>

      <div class="mt-10 flex flex-wrap gap-2">
        {phases.map(p => (
          <a
            href={`#phase-${p.num}`}
            class={`inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full text-sm font-semibold border ${colorMap[p.color].tag} hover:shadow-sm transition-shadow`}
          >
            <span class="font-display">{p.num}</span>
            <span>{p.short}</span>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- Why this matters -->
  <section class="bg-cream-50 py-14 sm:py-16 border-t border-cocoa/10">
    <div class="max-w-3xl mx-auto px-6">
      <div class="rounded-3xl border border-cocoa/15 bg-paper p-7 sm:p-9 retro-sheen">
        <h2 class="font-display font-semibold text-cocoa text-2xl mb-3">
          Why the framework matters, especially now
        </h2>
        <p class="text-cocoa/75 leading-relaxed">
          AI tooling has made it easy to produce <em>something</em> that looks like training. The constraint has moved. The hard part isn't generating content anymore. It's deciding what to build, how to measure whether it worked, and whether training is even the right fix. This framework is where those decisions get made on purpose.
        </p>
      </div>
    </div>
  </section>

  <!-- Phases -->
  <section class="bg-paper py-16 sm:py-20 border-t border-cocoa/10">
    <div class="max-w-4xl mx-auto px-6 space-y-14 sm:space-y-20">
      {phases.map(p => {
        const t = colorMap[p.color];
        return (
          <article id={`phase-${p.num}`} class="scroll-mt-24">
            <header class="flex items-start gap-5 mb-6">
              <span class={`font-display font-semibold text-5xl sm:text-6xl leading-none ${t.num}`}>
                {p.num}
              </span>
              <div class="pt-2">
                <p class="font-display text-xs uppercase tracking-widest text-cocoa/50 mb-1">Phase {p.num}</p>
                <h2 class="font-display font-semibold text-cocoa text-2xl sm:text-3xl leading-tight">
                  {p.title}
                </h2>
              </div>
            </header>

            <p class="text-lg text-cocoa/75 leading-relaxed mb-8 max-w-2xl">
              {p.pitch}
            </p>

            <div class={`grid md:grid-cols-2 gap-5`}>
              <div class={`rounded-2xl border ${t.border} ${t.bg} p-6`}>
                <h3 class="font-display font-semibold text-cocoa text-sm uppercase tracking-wider mb-3">
                  What happens
                </h3>
                <ul class="space-y-2 text-cocoa/80 text-[0.95rem] leading-relaxed">
                  {p.activities.map(a => (
                    <li class="flex gap-2">
                      <span class={`${t.num} font-bold mt-0.5`}>→</span>
                      <span>{a}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="rounded-2xl border border-cocoa/15 bg-cream-50 p-6">
                <h3 class="font-display font-semibold text-cocoa text-sm uppercase tracking-wider mb-3">
                  What comes out
                </h3>
                <ul class="space-y-2 text-cocoa/80 text-[0.95rem] leading-relaxed">
                  {p.outputs.map(o => (
                    <li class="flex gap-2">
                      <span class="text-cocoa/50 mt-0.5">•</span>
                      <span>{o}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <blockquote class="mt-6 border-l-4 border-accent-500 bg-accent-400/10 px-5 py-4 rounded-r-xl">
              <p class="font-display text-[1.05rem] text-cocoa/85 italic leading-relaxed">
                "{p.heuristic}"
              </p>
              <footer class="text-xs uppercase tracking-widest text-cocoa/50 mt-2">Heuristic</footer>
            </blockquote>
          </article>
        );
      })}
    </div>
  </section>

  <!-- CTA back to case studies -->
  <section class="bg-espresso py-16 text-cream relative overflow-hidden">
    <Sparkles class="absolute top-10 right-10 w-20 h-auto opacity-40 text-cream" />
    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display font-semibold text-3xl sm:text-4xl mb-4">
        See the framework <span class="italic text-accent-500">in action</span>
      </h2>
      <p class="text-cream/75 leading-relaxed mb-8 max-w-xl mx-auto">
        Each case study shows how these phases played out on a specific project: the decisions, the detours, the numbers.
      </p>
      <a
        href="/case-studies"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-accent-500 text-espresso font-semibold retro-sheen hover:bg-accent-400 transition-colors"
      >
        Browse case studies
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
