---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const all = (await getCollection('resources', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

// Quick grabs read in a couple of minutes; deep dives are the interactive guides.
const quick = all.filter(r => !r.data.embedUrl);
const deep = all.filter(r => r.data.embedUrl);

const typeColor: Record<string, { tag: string; ring: string }> = {
  'Framework':         { tag: 'bg-secondary-100 text-secondary-700 border-secondary-200', ring: 'from-secondary-100/60 to-cream-50' },
  'Template':          { tag: 'bg-primary-100 text-primary-700 border-primary-200',       ring: 'from-primary-100/60 to-cream-50' },
  'Prompt library':    { tag: 'bg-accent-400/25 text-accent-700 border-accent-500/40',    ring: 'from-accent-400/25 to-cream-50' },
  'Tool walkthrough':  { tag: 'bg-secondary-100 text-secondary-700 border-secondary-200', ring: 'from-secondary-100/60 to-cream-50' },
  'Case pattern':      { tag: 'bg-primary-100 text-primary-700 border-primary-200',       ring: 'from-primary-100/60 to-cream-50' },
  'Interactive':       { tag: 'bg-accent-400/25 text-accent-700 border-accent-500/40',    ring: 'from-accent-400/25 to-cream-50' },
  'Guide':             { tag: 'bg-secondary-100 text-secondary-700 border-secondary-200', ring: 'from-secondary-100/60 to-cream-50' },
};

function theme(type: string) {
  return typeColor[type] ?? typeColor['Template'];
}
---
<BaseLayout
  title="Free Resources"
  description="Free instructional design frameworks, prompts, and templates: the tools I actually use, shared as I build them."
>
  <section class="bg-cream-50 border-b-2 border-cocoa/15">
    <div class="relative max-w-4xl mx-auto px-6 py-14 sm:py-20">
      <p class="font-display text-sm uppercase tracking-widest text-cocoa/50 mb-3">Free resources</p>
      <h1 class="font-display font-semibold text-4xl sm:text-5xl text-cocoa tracking-tight leading-tight">
        The stuff I use, <span class="italic text-primary-600">shared freely</span>.
      </h1>
      <p class="mt-5 text-lg text-cocoa/75 max-w-2xl leading-relaxed">
        Tools for the people who <em>own</em> the outcome as much as the people who build the training. Quick grabs you can read in two minutes, plus a few deeper interactive guides. No email gate, take what's useful.
      </p>
    </div>
  </section>


  <!-- Quick grabs (bite-size, two-minute reads) -->
  {quick.length > 0 && (
    <section class="bg-cream-50 py-16 sm:py-20 border-t border-cocoa/10">
      <div class="max-w-6xl mx-auto px-6">
        <div class="mb-5">
          <p class="font-display text-sm uppercase tracking-widest text-cocoa/50">Quick grabs</p>
          <p class="text-cocoa/60 text-sm mt-1">Read in two minutes. Copy what's useful, skip the rest.</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {quick.map(r => {
            const t = theme(r.data.type);
            return (
              <a
                href={`/resources/${r.id}`}
                class="group flex flex-col rounded-2xl border border-cocoa/15 bg-paper p-5 sm:p-6 hover:border-primary-400 hover:shadow-lg hover:shadow-primary-600/10 transition-all"
              >
                <div class="flex items-center gap-2">
                  <span class={`inline-block px-2 py-0.5 rounded-full text-[11px] font-semibold border ${t.tag}`}>
                    {r.data.type}
                  </span>
                  {r.data.timeToUse && (
                    <span class="text-[11px] font-semibold text-cocoa/45">{r.data.timeToUse}</span>
                  )}
                </div>
                <h3 class="mt-3.5 font-display font-semibold text-lg text-cocoa leading-tight">
                  {r.data.title}
                </h3>
                <p class="mt-2 text-cocoa/70 leading-relaxed text-sm flex-1">
                  {r.data.blurb}
                </p>
                <span class="mt-4 text-sm font-semibold text-primary-600 inline-flex items-center gap-1 group-hover:gap-1.5 transition-all">
                  Open
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- Deep dives (the interactive guides) -->
  {deep.length > 0 && (
    <section class="bg-paper py-16 sm:py-20 border-t border-cocoa/10">
      <div class="max-w-6xl mx-auto px-6">
        <div class="mb-5">
          <p class="font-display text-sm uppercase tracking-widest text-cocoa/50">Deep dives</p>
          <p class="text-cocoa/60 text-sm mt-1">Interactive guides for when you want the whole picture.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {deep.map(r => {
            const t = theme(r.data.type);
            return (
              <a
                href={`/resources/${r.id}`}
                class="group relative block rounded-3xl border border-cocoa/15 bg-cream-50 p-6 sm:p-7 hover:border-primary-400 hover:shadow-xl hover:shadow-primary-600/10 transition-all"
              >
                <div class={`absolute inset-x-0 top-0 h-24 rounded-t-3xl bg-gradient-to-b ${t.ring} opacity-70 pointer-events-none`}></div>
                <div class="relative">
                  <div class="flex items-center gap-2">
                    <span class={`inline-block px-2.5 py-1 rounded-full text-xs font-semibold border ${t.tag}`}>
                      {r.data.type}
                    </span>
                    <span class="text-[11px] font-semibold text-cocoa/45">Interactive</span>
                  </div>
                  <h2 class="mt-5 font-display font-semibold text-xl text-cocoa leading-tight">
                    {r.data.title}
                  </h2>
                  <p class="mt-3 text-cocoa/70 leading-relaxed text-sm">
                    {r.data.blurb}
                  </p>
                  <div class="mt-5 flex items-center justify-between text-xs text-cocoa/55">
                    <span>{r.data.timeToUse ?? ''}</span>
                    <span class="font-semibold text-primary-600 group-hover:translate-x-0.5 transition-transform inline-flex items-center gap-1">
                      Open
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <section class="bg-[#111111] py-14 text-cream">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-display font-semibold text-2xl sm:text-3xl mb-3">
        Have something you want me to build?
      </h2>
      <p class="text-cream/75 leading-relaxed mb-6 max-w-xl mx-auto">
        If there's a template, prompt, or interactive pattern you'd use, tell me. A lot of what ends up here started as a request.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-accent-500 text-espresso font-semibold retro-sheen hover:bg-accent-400 transition-colors"
      >
        Suggest a resource
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
