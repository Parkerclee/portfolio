---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MoonStar from '../../components/decor/MoonStar.astro';
import WavyDivider from '../../components/decor/WavyDivider.astro';
import DemoPlayer from '../../components/DemoPlayer.astro';

export async function getStaticPaths() {
  const entries = await getCollection('resources', ({ data }) => !data.draft);
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const colorMap: Record<string, { badge: string; ring: string; italic: string }> = {
  terracotta: {
    badge: 'bg-primary-100 text-primary-700 border-primary-200',
    ring:  'from-primary-200/40 via-accent-400/20 to-cream-50',
    italic: 'text-primary-600',
  },
  avocado: {
    badge: 'bg-secondary-100 text-secondary-700 border-secondary-200',
    ring:  'from-secondary-200/40 via-accent-400/20 to-cream-50',
    italic: 'text-secondary-600',
  },
  mustard: {
    badge: 'bg-accent-400/25 text-accent-700 border-accent-500/40',
    ring:  'from-accent-400/40 via-primary-200/30 to-cream-50',
    italic: 'text-accent-700',
  },
};

const theme = colorMap[data.color] ?? colorMap.terracotta;
---
<BaseLayout title={data.title} description={data.blurb}>
  <section class={`relative overflow-hidden bg-gradient-to-br ${theme.ring} paper-bg`}>
    <MoonStar class="absolute top-8 left-6 sm:left-12 w-10 sm:w-14 h-auto opacity-90 hidden sm:block" />
    <div class="relative max-w-4xl mx-auto px-6 py-16 sm:py-24">
      <a href="/resources" class="inline-flex items-center gap-1 text-sm font-semibold text-cocoa/70 hover:text-primary-600 transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        All resources
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-5">
        <span class={`inline-block px-2.5 py-1 rounded-full text-xs font-semibold border ${theme.badge}`}>
          {data.type}
        </span>
        {data.timeToUse && (
          <span class="text-xs text-cocoa/55">· {data.timeToUse}</span>
        )}
      </div>

      <h1 class="font-display font-semibold text-cocoa text-3xl sm:text-4xl lg:text-5xl leading-tight tracking-tight">
        {data.title}
      </h1>

      <p class="mt-5 text-lg text-cocoa/75 leading-relaxed max-w-3xl">
        {data.blurb}
      </p>

      {data.tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-1.5">
          {data.tags.map(tag => (
            <span class="inline-block px-2.5 py-1 rounded-full text-[11px] font-semibold bg-cream-50 border border-cocoa/15 text-cocoa/75">
              {tag}
            </span>
          ))}
        </div>
      )}

      {(data.downloadUrl || data.externalUrl) && (
        <div class="mt-8 flex flex-wrap gap-3">
          {data.downloadUrl && (
            <a
              href={data.downloadUrl}
              download
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-primary-500 text-cream font-semibold retro-sheen hover:bg-primary-600 transition-colors"
            >
              {data.downloadLabel ?? 'Download'}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16" />
              </svg>
            </a>
          )}
          {data.externalUrl && (
            <a
              href={data.externalUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-cocoa/25 text-cocoa font-semibold hover:border-primary-500 hover:text-primary-600 transition-colors"
            >
              Open externally
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 3h7v7m0-7L10 14m-4 7h11a2 2 0 002-2v-7" />
              </svg>
            </a>
          )}
        </div>
      )}
    </div>
  </section>

  <WavyDivider class="-mt-2 relative z-10" />

  {data.embedUrl && (
    <section class="bg-cream-50 py-12 sm:py-14 border-b border-cocoa/10">
      <div class="max-w-5xl mx-auto px-6">
        <DemoPlayer src={data.embedUrl} title={data.title} minHeight={data.embedMinHeight ?? '680px'} />
      </div>
    </section>
  )}

  <article class="bg-paper py-16 sm:py-20">
    <div class="max-w-3xl mx-auto px-6 prose prose-cocoa">
      <Content />
    </div>
  </article>

  <section class="bg-[#111111] py-12 text-cream">
    <div class="max-w-3xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left">
      <p class="font-display text-lg">More like this →</p>
      <a
        href="/resources"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-accent-500 text-espresso font-semibold retro-sheen hover:bg-accent-400 transition-colors"
      >
        Browse all resources
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.75rem;
    line-height: 1.2;
    color: #553824;
    margin-top: 2.5rem;
    margin-bottom: 0.9rem;
    letter-spacing: -0.01em;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    color: #553824;
    margin-top: 1.75rem;
    margin-bottom: 0.6rem;
  }
  .prose :global(p) {
    color: rgba(85, 56, 36, 0.82);
    line-height: 1.75;
    margin: 1rem 0;
  }
  .prose :global(ul),
  .prose :global(ol) {
    margin: 1rem 0 1rem 1.5rem;
    color: rgba(85, 56, 36, 0.82);
    line-height: 1.75;
  }
  .prose :global(ul) { list-style: disc; }
  .prose :global(ol) { list-style: decimal; }
  .prose :global(li) { margin: 0.35rem 0; }
  .prose :global(strong) { color: #553824; font-weight: 600; }
  .prose :global(blockquote) {
    border-left: 3px solid #D9A441;
    padding: 0.75rem 1rem;
    margin: 1.5rem 0;
    background: rgba(217, 164, 65, 0.08);
    border-radius: 0 0.5rem 0.5rem 0;
    color: rgba(85, 56, 36, 0.75);
    font-style: italic;
  }
  .prose :global(blockquote p) { margin: 0; }
  .prose :global(a) {
    color: #A9522F;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose :global(a):hover { color: #8A4124; }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: rgba(85, 56, 36, 0.08);
    padding: 0.15rem 0.4rem;
    border-radius: 0.35rem;
  }
  .prose :global(pre) {
    padding: 1rem 1.1rem;
    border-radius: 0.7rem;
    overflow-x: auto;
    margin: 1.25rem 0;
    font-size: 0.85rem;
    line-height: 1.6;
    border: 1px solid rgba(85, 56, 36, 0.15);
  }
  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    font-size: inherit;
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px dashed rgba(85, 56, 36, 0.25);
    margin: 2.5rem 0;
  }
</style>
