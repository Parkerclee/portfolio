---
import BaseLayout from '../layouts/BaseLayout.astro';
import MoonStar from '../components/decor/MoonStar.astro';
import Sparkles from '../components/decor/Sparkles.astro';

// NOTE: The contact form uses a client-side mailto fallback by default,
// so the site stays fully static on Vercel. To wire up a real backend,
// sign up for Formspree (or similar) and set FORM_ENDPOINT below to
// the returned endpoint URL. The form will automatically switch from
// mailto to a POST submission.
const FORM_ENDPOINT = ''; // e.g. 'https://formspree.io/f/abcd1234'
const CONTACT_EMAIL = 'hello@parkerlee.dev';
---
<BaseLayout
  title="Contact"
  description="Work with Parker Lee on putting AI to work in your L&D or knowledge management, or building custom, company-specific AI training."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-paper paper-bg">
    <MoonStar class="absolute top-10 left-6 sm:left-12 w-10 sm:w-14 h-auto opacity-90 hidden sm:block" />
    <Sparkles class="hidden md:block absolute bottom-8 right-8 w-28 lg:w-36 h-auto opacity-80 pointer-events-none" />

    <div class="relative max-w-4xl mx-auto px-6 py-20 sm:py-24">
      <p class="font-display text-sm uppercase tracking-widest text-cocoa/50 mb-3">Let's talk</p>
      <h1 class="font-display font-semibold text-cocoa text-4xl sm:text-5xl lg:text-6xl leading-tight tracking-tight">
        Tell me about the <span class="italic text-primary-600">problem</span>.
      </h1>
      <p class="mt-6 text-lg text-cocoa/75 leading-relaxed max-w-2xl">
        Whether you're scoping a compliance rebuild, an LMS migration, or a "we don't know if we need training at all" conversation, I'd love to hear about it. I respond within two business days.
      </p>
    </div>
  </section>


  <!-- Form + direct channels -->
  <section class="bg-cream-50 py-16 sm:py-20 border-t border-cocoa/10">
    <div class="max-w-5xl mx-auto px-6 grid lg:grid-cols-[3fr_2fr] gap-8 lg:gap-12 items-start">

      <!-- Form -->
      <div class="rounded-3xl border border-cocoa/15 bg-paper p-7 sm:p-9 retro-sheen">
        <h2 class="font-display font-semibold text-cocoa text-2xl mb-2">
          Send a message
        </h2>
        <p class="text-cocoa/70 text-sm leading-relaxed mb-6">
          Fill this out and I'll get back to you. The more context you can share, the more useful my first reply will be.
        </p>

        <form
          id="contactForm"
          data-endpoint={FORM_ENDPOINT}
          data-mailto={CONTACT_EMAIL}
          class="space-y-4"
          novalidate
        >
          <div class="grid sm:grid-cols-2 gap-4">
            <label class="block">
              <span class="block font-display text-[11px] uppercase tracking-widest text-cocoa/60 mb-1.5">Your name</span>
              <input
                type="text"
                name="name"
                required
                class="block w-full px-3.5 py-2.5 rounded-xl border border-cocoa/20 bg-cream-50 text-cocoa placeholder:text-cocoa/40 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/25 transition"
                placeholder="e.g., Morgan Lee"
              />
            </label>
            <label class="block">
              <span class="block font-display text-[11px] uppercase tracking-widest text-cocoa/60 mb-1.5">Email</span>
              <input
                type="email"
                name="email"
                required
                class="block w-full px-3.5 py-2.5 rounded-xl border border-cocoa/20 bg-cream-50 text-cocoa placeholder:text-cocoa/40 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/25 transition"
                placeholder="morgan@acme.co"
              />
            </label>
          </div>

          <label class="block">
            <span class="block font-display text-[11px] uppercase tracking-widest text-cocoa/60 mb-1.5">Company / Team</span>
            <input
              type="text"
              name="company"
              class="block w-full px-3.5 py-2.5 rounded-xl border border-cocoa/20 bg-cream-50 text-cocoa placeholder:text-cocoa/40 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/25 transition"
              placeholder="Optional"
            />
          </label>

          <fieldset class="block">
            <legend class="font-display text-[11px] uppercase tracking-widest text-cocoa/60 mb-2">
              What's this about?
            </legend>
            <div class="flex flex-wrap gap-2">
              {['New project', 'Consultation', 'Speaking / content', 'Just curious'].map(topic => (
                <label class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-cocoa/20 bg-cream-50 text-sm text-cocoa/80 cursor-pointer hover:border-primary-400 transition has-[:checked]:bg-primary-500 has-[:checked]:text-cream has-[:checked]:border-primary-500">
                  <input type="radio" name="topic" value={topic} class="sr-only" />
                  {topic}
                </label>
              ))}
            </div>
          </fieldset>

          <label class="block">
            <span class="block font-display text-[11px] uppercase tracking-widest text-cocoa/60 mb-1.5">Your message</span>
            <textarea
              name="message"
              required
              rows="6"
              class="block w-full px-3.5 py-2.5 rounded-xl border border-cocoa/20 bg-cream-50 text-cocoa placeholder:text-cocoa/40 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/25 transition resize-y"
              placeholder="What's the problem? What's already been tried? What does success look like?"
            ></textarea>
          </label>

          <!-- Honeypot (spam trap) -->
          <input
            type="text"
            name="website"
            tabindex="-1"
            autocomplete="off"
            class="hidden"
            aria-hidden="true"
          />

          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 pt-2">
            <p id="formStatus" class="text-sm text-cocoa/60 min-h-[1.25rem]" aria-live="polite"></p>
            <button
              type="submit"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full bg-primary-500 text-cream font-semibold retro-sheen hover:bg-primary-600 transition-colors"
            >
              Send message
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </button>
          </div>
        </form>
      </div>

      <!-- Direct channels -->
      <aside class="space-y-5">
        <div class="rounded-3xl border border-cocoa/15 bg-paper p-6">
          <p class="font-display text-[11px] uppercase tracking-widest text-cocoa/50 mb-2">
            Prefer direct?
          </p>
          <a
            href={`mailto:${CONTACT_EMAIL}`}
            class="font-display font-semibold text-cocoa text-xl hover:text-primary-600 transition-colors"
          >
            {CONTACT_EMAIL}
          </a>
          <p class="mt-3 text-sm text-cocoa/65 leading-relaxed">
            Email is usually fastest. I reply to everything within two business days.
          </p>
        </div>

        <div class="rounded-3xl border border-cocoa/15 bg-paper p-6 space-y-3">
          <p class="font-display text-[11px] uppercase tracking-widest text-cocoa/50 mb-1">
            Other places
          </p>
          <a
            href="https://www.linkedin.com/in/parkerlee/"
            target="_blank"
            rel="noopener"
            class="flex items-center justify-between gap-3 px-4 py-3 rounded-xl border border-cocoa/15 bg-cream-50 hover:border-primary-400 transition-colors group"
          >
            <span class="flex items-center gap-3">
              <svg class="w-5 h-5 text-cocoa" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.327-.026-3.036-1.849-3.036-1.85 0-2.132 1.445-2.132 2.94v5.665H9.358V9h3.414v1.561h.046c.475-.9 1.637-1.85 3.37-1.85 3.6 0 4.268 2.37 4.268 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zM7.119 20.452H3.554V9h3.565v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              <span class="font-semibold text-cocoa">LinkedIn</span>
            </span>
            <svg class="w-4 h-4 text-cocoa/40 group-hover:text-primary-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
          <a
            href="https://github.com/Parkerclee"
            target="_blank"
            rel="noopener"
            class="flex items-center justify-between gap-3 px-4 py-3 rounded-xl border border-cocoa/15 bg-cream-50 hover:border-primary-400 transition-colors group"
          >
            <span class="flex items-center gap-3">
              <svg class="w-5 h-5 text-cocoa" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.30 3.438 9.8 8.205 11.385.6.11.82-.26.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.332-1.755-1.332-1.755-1.09-.744.083-.73.083-.73 1.204.085 1.838 1.236 1.838 1.236 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.605-2.665-.303-5.467-1.332-5.467-5.93 0-1.31.467-2.382 1.235-3.222-.124-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.301 1.23A11.52 11.52 0 0112 5.803c1.02.004 2.047.137 3.004.403 2.29-1.552 3.297-1.23 3.297-1.23.655 1.653.243 2.873.12 3.176.77.84 1.233 1.912 1.233 3.222 0 4.61-2.807 5.624-5.48 5.92.43.37.815 1.103.815 2.22 0 1.606-.015 2.898-.015 3.293 0 .32.217.694.826.576C20.565 21.796 24 17.297 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
              <span class="font-semibold text-cocoa">GitHub</span>
            </span>
            <svg class="w-4 h-4 text-cocoa/40 group-hover:text-primary-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>

        <div class="rounded-3xl border border-dashed border-secondary-600/40 bg-secondary-100/40 p-6">
          <p class="font-display text-[11px] uppercase tracking-widest text-secondary-700 mb-2">
            Currently
          </p>
          <p class="font-display text-cocoa font-semibold text-lg leading-tight">
            Open to new engagements
          </p>
          <p class="mt-2 text-sm text-cocoa/70 leading-relaxed">
            Full-time, fractional, or project work. Particular interest in AI-for-L&D implementation.
          </p>
        </div>
      </aside>

    </div>
  </section>

  <script is:inline>
    // Contact form — static-friendly.
    // If data-endpoint is set, POSTs JSON to that endpoint (e.g. Formspree).
    // Otherwise, composes a mailto link so the site stays backend-free.
    (() => {
      const form = document.getElementById('contactForm');
      if (!form) return;
      const status = document.getElementById('formStatus');
      const endpoint = form.dataset.endpoint || '';
      const mailto = form.dataset.mailto || '';

      function setStatus(msg, tone) {
        if (!status) return;
        status.textContent = msg;
        status.style.color = tone === 'error' ? '#A9522F'
                           : tone === 'success' ? '#5A6733'
                           : '';
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form);

        // Honeypot check
        if (data.get('website')) {
          setStatus('Something went wrong. Please try again.', 'error');
          return;
        }

        const payload = {
          name: (data.get('name') || '').toString().trim(),
          email: (data.get('email') || '').toString().trim(),
          company: (data.get('company') || '').toString().trim(),
          topic: (data.get('topic') || '').toString().trim(),
          message: (data.get('message') || '').toString().trim(),
        };

        if (!payload.name || !payload.email || !payload.message) {
          setStatus('Please fill in name, email, and message.', 'error');
          return;
        }

        if (endpoint) {
          try {
            setStatus('Sending…');
            const res = await fetch(endpoint, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify(payload),
            });
            if (res.ok) {
              setStatus('Thanks, I\'ll reply within two business days.', 'success');
              form.reset();
            } else {
              setStatus('Something went wrong. Email is always open too.', 'error');
            }
          } catch (err) {
            setStatus('Network error. Try the direct email instead?', 'error');
          }
          return;
        }

        // Mailto fallback
        const subject = encodeURIComponent(
          `[Portfolio] ${payload.topic || 'Hello'} · ${payload.name}`
        );
        const body = encodeURIComponent(
`Hi Parker,

${payload.message}

--
${payload.name}${payload.company ? ` · ${payload.company}` : ''}
${payload.email}`
        );
        const href = `mailto:${mailto}?subject=${subject}&body=${body}`;
        window.location.href = href;
        setStatus('Opening your email client…', 'success');
      });
    })();
  </script>
</BaseLayout>
