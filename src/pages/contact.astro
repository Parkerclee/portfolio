---
import BaseLayout from '../layouts/BaseLayout.astro';
import MoonStar from '../components/decor/MoonStar.astro';
import Sparkles from '../components/decor/Sparkles.astro';

const LINKEDIN_URL = 'https://www.linkedin.com/in/parkerclee/';
const GITHUB_URL = 'https://github.com/Parkerclee';
const CONTACT_EMAIL = 'hello@parkerlee.work';
---
<BaseLayout
  title="Contact"
  description="Work with Parker Lee on putting AI to work in your L&D or knowledge management, or building custom, company-specific AI training. Reach out on LinkedIn."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-paper paper-bg">
    <MoonStar class="absolute top-10 left-6 sm:left-12 w-10 sm:w-14 h-auto opacity-90 hidden sm:block" />
    <Sparkles class="hidden md:block absolute bottom-8 right-8 w-28 lg:w-36 h-auto opacity-80 pointer-events-none" />

    <div class="relative max-w-4xl mx-auto px-6 py-20 sm:py-24">
      <p class="font-display text-sm uppercase tracking-widest text-cocoa/50 mb-3">Let's talk</p>
      <h1 class="font-display font-semibold text-cocoa text-4xl sm:text-5xl lg:text-6xl leading-tight tracking-tight">
        Tell me about the <span class="italic text-primary-600">problem</span>.
      </h1>
      <p class="mt-6 text-lg text-cocoa/75 leading-relaxed max-w-2xl">
        Whether you're scoping a compliance rebuild, an LMS migration, or a "we don't know if we need training at all" conversation, I'd love to hear about it. LinkedIn is the fastest way to reach me.
      </p>
    </div>
  </section>

  <!-- Channels -->
  <section class="bg-cream-50 py-16 sm:py-20 border-t border-cocoa/10">
    <div class="max-w-3xl mx-auto px-6">

      <!-- Primary: LinkedIn -->
      <a
        href={LINKEDIN_URL}
        target="_blank"
        rel="noopener"
        class="group block rounded-3xl border border-cocoa/15 bg-paper p-7 sm:p-9 retro-sheen hover:border-primary-400 transition-colors"
      >
        <div class="flex items-start gap-5">
          <span class="shrink-0 w-14 h-14 rounded-2xl bg-primary-500 text-cream flex items-center justify-center retro-sheen">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.327-.026-3.036-1.849-3.036-1.85 0-2.132 1.445-2.132 2.94v5.665H9.358V9h3.414v1.561h.046c.475-.9 1.637-1.85 3.37-1.85 3.6 0 4.268 2.37 4.268 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zM7.119 20.452H3.554V9h3.565v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </span>
          <div class="min-w-0">
            <p class="font-display text-[11px] uppercase tracking-widest text-cocoa/50 mb-1">
              Best way to reach me
            </p>
            <h2 class="font-display font-semibold text-cocoa text-2xl mb-1 group-hover:text-primary-600 transition-colors">
              Connect on LinkedIn
            </h2>
            <p class="text-cocoa/70 text-[0.98rem] leading-relaxed">
              Send a message or connection request and tell me what you're working on. I reply to everything within two business days.
            </p>
          </div>
          <svg class="hidden sm:block w-5 h-5 text-cocoa/30 group-hover:text-primary-600 transition-colors mt-2 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </div>
      </a>

      <!-- Secondary: email + github -->
      <div class="grid sm:grid-cols-2 gap-5 mt-5">
        <a
          href={`mailto:${CONTACT_EMAIL}`}
          class="group rounded-3xl border border-cocoa/15 bg-paper p-6 hover:border-primary-400 transition-colors"
        >
          <p class="font-display text-[11px] uppercase tracking-widest text-cocoa/50 mb-2">
            Prefer email?
          </p>
          <span class="font-display font-semibold text-cocoa text-lg group-hover:text-primary-600 transition-colors break-all">
            {CONTACT_EMAIL}
          </span>
          <p class="mt-2 text-sm text-cocoa/65 leading-relaxed">
            Works just as well. The more context you share, the more useful my first reply.
          </p>
        </a>

        <a
          href={GITHUB_URL}
          target="_blank"
          rel="noopener"
          class="group rounded-3xl border border-cocoa/15 bg-paper p-6 hover:border-primary-400 transition-colors"
        >
          <p class="font-display text-[11px] uppercase tracking-widest text-cocoa/50 mb-2">
            See the code
          </p>
          <span class="flex items-center gap-2 font-display font-semibold text-cocoa text-lg group-hover:text-primary-600 transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.30 3.438 9.8 8.205 11.385.6.11.82-.26.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.332-1.755-1.332-1.755-1.09-.744.083-.73.083-.73 1.204.085 1.838 1.236 1.838 1.236 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.605-2.665-.303-5.467-1.332-5.467-5.93 0-1.31.467-2.382 1.235-3.222-.124-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.301 1.23A11.52 11.52 0 0112 5.803c1.02.004 2.047.137 3.004.403 2.29-1.552 3.297-1.23 3.297-1.23.655 1.653.243 2.873.12 3.176.77.84 1.233 1.912 1.233 3.222 0 4.61-2.807 5.624-5.48 5.92.43.37.815 1.103.815 2.22 0 1.606-.015 2.898-.015 3.293 0 .32.217.694.826.576C20.565 21.796 24 17.297 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub
          </span>
          <p class="mt-2 text-sm text-cocoa/65 leading-relaxed">
            This site and the demos are open. Have a look at how they're built.
          </p>
        </a>
      </div>

      <!-- Availability -->
      <div class="rounded-3xl border border-dashed border-secondary-600/40 bg-secondary-100/40 p-6 mt-5">
        <p class="font-display text-[11px] uppercase tracking-widest text-secondary-700 mb-2">
          Currently
        </p>
        <p class="font-display text-cocoa font-semibold text-lg leading-tight">
          Open to new engagements
        </p>
        <p class="mt-2 text-sm text-cocoa/70 leading-relaxed">
          Full-time, fractional, or project work. Particular interest in AI-for-L&D implementation.
        </p>
      </div>

    </div>
  </section>
</BaseLayout>
