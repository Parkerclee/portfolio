---
import BaseLayout from '../layouts/BaseLayout.astro';
import MoonStar from '../components/decor/MoonStar.astro';
import Sparkles from '../components/decor/Sparkles.astro';
import WavyDivider from '../components/decor/WavyDivider.astro';

const companies = [
  {
    id: 'meridian',
    name: 'Meridian Financial',
    color: 'terracotta',
    blurb: 'Compliance onboarding · Rise 360 + xAPI · 10-week engagement',
    kpis: [
      { label: 'Time-to-proficiency', value: '6.1 wks', delta: '−48%', baseline: 'vs. 12-wk baseline', good: true },
      { label: 'Capstone pass rate', value: '88%', delta: '+27pts', baseline: 'vs. 61% pilot', good: true },
      { label: 'Audit findings (focus 4)', value: '−72%', delta: '', baseline: '90-day window', good: true },
      { label: 'Completion rate', value: '91%', delta: '+43pts', baseline: 'vs. 48% legacy', good: true },
    ],
    case: '/case-studies/meridian-financial',
  },
  {
    id: 'crestline',
    name: 'Crestline Health',
    color: 'avocado',
    blurb: 'EHR migration · code-built simulator + xAPI · 8-week engagement',
    kpis: [
      { label: 'System adoption', value: '91%', delta: '+39pts', baseline: 'vs. 52% pre-rollout', good: true },
      { label: 'First-attempt completion', value: '74%', delta: '', baseline: 'across 9 workflows', good: true },
      { label: 'Help-desk tickets', value: '−63%', delta: '', baseline: '30 days post-launch', good: true },
      { label: 'Clinicians trained', value: '1,847', delta: '', baseline: '3 departments', good: true },
    ],
    case: '/case-studies/crestline-health',
    demo: '/demos/ehr-simulator',
  },
  {
    id: 'basecamp',
    name: 'Basecamp Retail',
    color: 'mustard',
    blurb: 'E-bike launch · blended curriculum · 12-week engagement',
    kpis: [
      { label: 'Mystery shopper mean', value: '86', delta: '+18pts', baseline: 'vs. 68 baseline' , good: true },
      { label: 'Score variance', value: '−42%', delta: '', baseline: 'range compression', good: true },
      { label: 'Associates certified', value: '4,120', delta: '', baseline: 'across 200+ stores', good: true },
      { label: 'E-bike attach rate', value: '+28%', delta: '', baseline: 'vs. prior launches', good: true },
    ],
    case: '/case-studies/basecamp-retail',
  },
];
---
<BaseLayout
  title="Analytics Dashboard"
  description="xAPI-driven analytics from three case studies — visualized with Chart.js."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-paper paper-bg">
    <MoonStar class="absolute top-10 left-6 sm:left-12 w-10 sm:w-14 h-auto opacity-90 hidden sm:block" />
    <Sparkles class="hidden md:block absolute bottom-10 right-10 w-28 lg:w-36 h-auto opacity-80 pointer-events-none" />

    <div class="relative max-w-5xl mx-auto px-6 py-16 sm:py-20">
      <p class="font-display text-sm uppercase tracking-widest text-cocoa/50 mb-3">Phase 6 · xAPI pipeline</p>
      <h1 class="font-display font-semibold text-cocoa text-4xl sm:text-5xl lg:text-6xl leading-tight tracking-tight">
        Learning analytics, <span class="italic text-primary-600">visualized</span>.
      </h1>
      <p class="mt-5 text-lg text-cocoa/75 leading-relaxed max-w-3xl">
        Every demo in this portfolio is designed to emit xAPI statements into an LRS. This dashboard shows what those statements look like once they're aggregated — mapped to the Kirkpatrick level the sponsor actually cares about, not just completion counts.
      </p>

      <div class="mt-6 inline-flex items-center gap-2 rounded-full border border-cocoa/15 bg-cream-50 px-4 py-1.5 text-xs font-semibold text-cocoa/70 font-display uppercase tracking-widest">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-accent-500"></span>
        Synthetic data representing live pipeline output
      </div>
    </div>
  </section>

  <WavyDivider class="-mt-2 relative z-10" />

  <!-- Company switcher -->
  <section class="bg-cream-50 pt-12 pb-6">
    <div class="max-w-6xl mx-auto px-6">
      <p class="font-display text-xs uppercase tracking-widest text-cocoa/50 mb-3">Select a case study</p>
      <div class="flex flex-wrap gap-2" role="tablist" aria-label="Case study selector">
        {companies.map((c, i) => (
          <button
            type="button"
            role="tab"
            id={`tab-${c.id}`}
            data-company-tab={c.id}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${c.id}`}
            class="company-tab group inline-flex items-center gap-2.5 px-4 py-2.5 rounded-full border border-cocoa/15 bg-paper text-cocoa font-semibold text-sm transition-all hover:border-cocoa/30 data-[active=true]:bg-cocoa data-[active=true]:text-cream data-[active=true]:border-cocoa"
            data-active={i === 0 ? 'true' : 'false'}
          >
            <span
              class="w-2 h-2 rounded-full"
              style={`background: var(--company-swatch-${c.color});`}
            ></span>
            {c.name}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Panels (one per company; JS toggles visibility) -->
  <section class="bg-cream-50 pb-20">
    <div class="max-w-6xl mx-auto px-6">
      {companies.map((c, i) => (
        <div
          id={`panel-${c.id}`}
          role="tabpanel"
          aria-labelledby={`tab-${c.id}`}
          class="company-panel mt-8 space-y-8"
          data-company-panel={c.id}
          data-color={c.color}
          hidden={i !== 0}
        >
          <!-- Context strip -->
          <header class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 pb-2">
            <div>
              <h2 class="font-display font-semibold text-cocoa text-2xl sm:text-3xl leading-tight">
                {c.name}
              </h2>
              <p class="mt-1 text-cocoa/60 text-sm">{c.blurb}</p>
            </div>
            <div class="flex flex-wrap gap-2">
              <a href={c.case} class="inline-flex items-center gap-1 text-sm font-semibold text-primary-600 hover:underline underline-offset-4">
                Read the case study →
              </a>
              {c.demo && (
                <a href={c.demo} class="inline-flex items-center gap-1 text-sm font-semibold text-cocoa/70 hover:text-primary-600 hover:underline underline-offset-4">
                  · Try the demo
                </a>
              )}
            </div>
          </header>

          <!-- KPI cards -->
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
            {c.kpis.map(k => (
              <div class={`rounded-2xl border border-cocoa/15 bg-paper p-5 retro-sheen`}>
                <p class="font-display text-[11px] uppercase tracking-widest text-cocoa/50 mb-2">
                  {k.label}
                </p>
                <p class="font-display font-semibold text-cocoa text-3xl leading-none">
                  {k.value}
                </p>
                <div class="mt-2 flex items-baseline gap-2 text-xs">
                  {k.delta && (
                    <span class={`font-semibold ${k.good ? 'text-secondary-600' : 'text-primary-600'}`}>
                      {k.delta}
                    </span>
                  )}
                  <span class="text-cocoa/55">{k.baseline}</span>
                </div>
              </div>
            ))}
          </div>

          <!-- Chart grid -->
          <div class="grid lg:grid-cols-2 gap-4 sm:gap-5">
            <article class="rounded-2xl border border-cocoa/15 bg-paper p-5 sm:p-6">
              <header class="mb-4">
                <p class="font-display text-[11px] uppercase tracking-widest text-cocoa/50">
                  Kirkpatrick Level 2
                </p>
                <h3 class="font-display font-semibold text-cocoa text-lg leading-tight">
                  <span data-chart-title={`${c.id}-1`}>Chart 1</span>
                </h3>
              </header>
              <div class="relative h-64 sm:h-72">
                <canvas data-chart={`${c.id}-1`}></canvas>
              </div>
            </article>

            <article class="rounded-2xl border border-cocoa/15 bg-paper p-5 sm:p-6">
              <header class="mb-4">
                <p class="font-display text-[11px] uppercase tracking-widest text-cocoa/50">
                  Kirkpatrick Level 3
                </p>
                <h3 class="font-display font-semibold text-cocoa text-lg leading-tight">
                  <span data-chart-title={`${c.id}-2`}>Chart 2</span>
                </h3>
              </header>
              <div class="relative h-64 sm:h-72">
                <canvas data-chart={`${c.id}-2`}></canvas>
              </div>
            </article>

            <article class="rounded-2xl border border-cocoa/15 bg-paper p-5 sm:p-6">
              <header class="mb-4">
                <p class="font-display text-[11px] uppercase tracking-widest text-cocoa/50">
                  Decision-level detail
                </p>
                <h3 class="font-display font-semibold text-cocoa text-lg leading-tight">
                  <span data-chart-title={`${c.id}-3`}>Chart 3</span>
                </h3>
              </header>
              <div class="relative h-64 sm:h-72">
                <canvas data-chart={`${c.id}-3`}></canvas>
              </div>
            </article>

            <article class="rounded-2xl border border-cocoa/15 bg-paper p-5 sm:p-6">
              <header class="mb-4">
                <p class="font-display text-[11px] uppercase tracking-widest text-cocoa/50">
                  Cohort breakdown
                </p>
                <h3 class="font-display font-semibold text-cocoa text-lg leading-tight">
                  <span data-chart-title={`${c.id}-4`}>Chart 4</span>
                </h3>
              </header>
              <div class="relative h-64 sm:h-72">
                <canvas data-chart={`${c.id}-4`}></canvas>
              </div>
            </article>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- About the data -->
  <section class="bg-paper border-t border-cocoa/10 py-14">
    <div class="max-w-3xl mx-auto px-6">
      <div class="rounded-3xl border border-cocoa/15 bg-cream-50 p-7 sm:p-9">
        <h2 class="font-display font-semibold text-cocoa text-2xl mb-3">
          About this data
        </h2>
        <p class="text-cocoa/75 leading-relaxed mb-3">
          The three companies are fictional, so the numbers are synthetic. They're not made-up <em>to look good</em> — they're modeled on the order of magnitude I've seen on real engagements, and the deltas are consistent with published benchmarks for compliance training, EHR migrations, and retail behavior change.
        </p>
        <p class="text-cocoa/75 leading-relaxed">
          In a live engagement, the same dashboard would be fed by xAPI statements posted to SCORM Cloud (or a client LRS), aggregated by a small ingestion layer, and sliced by cohort, role, and scenario. The charts render with Chart.js against whatever shape the LRS returns — swapping in real data is a configuration change, not a rebuild.
        </p>
      </div>
    </div>
  </section>

  <style>
    /* Expose CSS custom properties for swatch colors used above */
    :root {
      --company-swatch-terracotta: #C4663D;
      --company-swatch-avocado: #6E7C3F;
      --company-swatch-mustard: #D9A441;
    }
    .company-tab {
      cursor: pointer;
    }
    .company-tab[data-active="true"] {
      box-shadow: 0 4px 12px -4px rgba(85, 56, 36, 0.25);
    }
  </style>

  <!-- Client: data + chart rendering -->
  <script>
    import { Chart, registerables } from 'chart.js';
    Chart.register(...registerables);

    // ---- Forest palette (for chart colors) -------------------------
    const palette = {
      terracotta: {
        solid: '#C4663D',
        soft: 'rgba(196, 102, 61, 0.18)',
        ring: 'rgba(196, 102, 61, 0.55)',
      },
      avocado: {
        solid: '#6E7C3F',
        soft: 'rgba(110, 124, 63, 0.18)',
        ring: 'rgba(110, 124, 63, 0.55)',
      },
      mustard: {
        solid: '#D9A441',
        soft: 'rgba(217, 164, 65, 0.22)',
        ring: 'rgba(217, 164, 65, 0.6)',
      },
      cocoa: '#553824',
      cocoaSoft: 'rgba(85, 56, 36, 0.55)',
      cream: '#FBF4E2',
      grid: 'rgba(85, 56, 36, 0.1)',
    };

    // Global Chart.js defaults tuned for the portfolio palette
    Chart.defaults.font.family = '"Plus Jakarta Sans", system-ui, sans-serif';
    Chart.defaults.font.size = 12;
    Chart.defaults.color = palette.cocoaSoft;
    Chart.defaults.borderColor = palette.grid;

    // ---- Mock datasets per company ---------------------------------
    const data = {
      meridian: {
        titles: {
          1: 'First-attempt pass rate by decision',
          2: 'Audit findings — 4 focus decisions, 90-day window',
          3: 'Time-to-proficiency by cohort (weeks)',
          4: 'Completion status · active cohort',
        },
        chart1: {
          type: 'bar',
          data: {
            labels: ['Adverse action', 'Reg Z APR', 'Reg B denial', 'Fair lending'],
            datasets: [{
              label: 'Pass rate (%)',
              data: [84, 91, 86, 88],
              backgroundColor: palette.terracotta.soft,
              borderColor: palette.terracotta.solid,
              borderWidth: 2,
              borderRadius: 6,
            }],
          },
        },
        chart2: {
          type: 'bar',
          data: {
            labels: ['Adverse action', 'Reg Z APR', 'Reg B denial', 'Fair lending'],
            datasets: [
              {
                label: 'Pre-training',
                data: [14, 11, 9, 13],
                backgroundColor: palette.cocoaSoft,
                borderRadius: 4,
              },
              {
                label: 'Post-training',
                data: [4, 3, 2, 4],
                backgroundColor: palette.terracotta.solid,
                borderRadius: 4,
              },
            ],
          },
        },
        chart3: {
          type: 'line',
          data: {
            labels: ['Pre-launch', 'Cohort 1', 'Cohort 2', 'Cohort 3', 'Cohort 4'],
            datasets: [{
              label: 'Weeks to proficiency',
              data: [12.1, 8.4, 7.2, 6.5, 6.1],
              borderColor: palette.terracotta.solid,
              backgroundColor: palette.terracotta.soft,
              fill: true,
              tension: 0.35,
              pointRadius: 4,
              pointBackgroundColor: palette.terracotta.solid,
            }],
          },
        },
        chart4: {
          type: 'doughnut',
          data: {
            labels: ['Completed', 'In progress', 'Not started'],
            datasets: [{
              data: [91, 7, 2],
              backgroundColor: [palette.terracotta.solid, palette.mustard.solid, palette.cocoaSoft],
              borderColor: palette.cream,
              borderWidth: 3,
            }],
          },
        },
      },

      crestline: {
        titles: {
          1: 'First-attempt completion by workflow',
          2: 'EHR-related help-desk tickets · 30-day pre/post',
          3: 'Allergy branching · decision outcomes',
          4: 'Adoption by department',
        },
        chart1: {
          type: 'bar',
          data: {
            labels: ['ED admit', 'D/C + med rec', 'Routine lab', 'STAT lab', 'Code blue', 'Consult', 'Transfer', 'Rounding', 'Refused med'],
            datasets: [{
              label: 'First-attempt (%)',
              data: [78, 71, 83, 69, 66, 76, 74, 81, 72],
              backgroundColor: palette.avocado.soft,
              borderColor: palette.avocado.solid,
              borderWidth: 2,
              borderRadius: 5,
            }],
          },
          options: {
            indexAxis: 'y',
          },
        },
        chart2: {
          type: 'line',
          data: {
            labels: ['Wk −4', 'Wk −3', 'Wk −2', 'Wk −1', 'Launch', 'Wk +1', 'Wk +2', 'Wk +3', 'Wk +4'],
            datasets: [{
              label: 'Daily avg tickets',
              data: [48, 52, 50, 47, 68, 44, 31, 22, 18],
              borderColor: palette.avocado.solid,
              backgroundColor: palette.avocado.soft,
              fill: true,
              tension: 0.3,
              pointRadius: 3,
              pointBackgroundColor: palette.avocado.solid,
            }],
          },
        },
        chart3: {
          type: 'bar',
          data: {
            labels: ['Wk 1', 'Wk 2', 'Wk 3', 'Wk 4', 'Wk 5', 'Wk 6'],
            datasets: [
              {
                label: 'Safe cancel',
                data: [42, 38, 34, 28, 22, 19],
                backgroundColor: palette.avocado.solid,
                stack: 'a',
                borderRadius: { topLeft: 0, topRight: 0 },
              },
              {
                label: 'Alternative chosen',
                data: [48, 55, 62, 69, 76, 79],
                backgroundColor: palette.mustard.solid,
                stack: 'a',
              },
              {
                label: 'Blocked override',
                data: [10, 7, 4, 3, 2, 2],
                backgroundColor: palette.terracotta.solid,
                stack: 'a',
                borderRadius: 3,
              },
            ],
          },
          options: {
            scales: {
              x: { stacked: true, grid: { display: false } },
              y: { stacked: true, beginAtZero: true, max: 100, ticks: { callback: (v) => v + '%' } },
            },
          },
        },
        chart4: {
          type: 'doughnut',
          data: {
            labels: ['ED', 'Med-Surg', 'Outpatient'],
            datasets: [{
              data: [94, 89, 90],
              backgroundColor: [palette.avocado.solid, palette.mustard.solid, palette.terracotta.solid],
              borderColor: palette.cream,
              borderWidth: 3,
            }],
          },
        },
      },

      basecamp: {
        titles: {
          1: 'Mystery shopper scores by quarter',
          2: 'Store-score variance · pre vs. 90 days post',
          3: 'Observation rubric · pass rate by cluster',
          4: 'E-bike conversation quality',
        },
        chart1: {
          type: 'line',
          data: {
            labels: ['Q1 (pre)', 'Q2 (pre)', 'Q3 launch', 'Q4 (+30d)', 'Q1 next (+90d)'],
            datasets: [
              {
                label: 'Chain mean',
                data: [66, 68, 74, 82, 86],
                borderColor: palette.mustard.solid,
                backgroundColor: palette.mustard.soft,
                fill: true,
                tension: 0.35,
                pointRadius: 4,
                pointBackgroundColor: palette.mustard.solid,
              },
              {
                label: 'Bottom decile',
                data: [45, 44, 58, 71, 78],
                borderColor: palette.terracotta.solid,
                borderDash: [5, 4],
                fill: false,
                tension: 0.35,
                pointRadius: 3,
                pointBackgroundColor: palette.terracotta.solid,
              },
              {
                label: 'Top decile',
                data: [91, 92, 93, 94, 95],
                borderColor: palette.avocado.solid,
                borderDash: [5, 4],
                fill: false,
                tension: 0.35,
                pointRadius: 3,
                pointBackgroundColor: palette.avocado.solid,
              },
            ],
          },
        },
        chart2: {
          type: 'bar',
          data: {
            labels: ['Bottom', 'Q2', 'Median', 'Q4', 'Top'],
            datasets: [
              {
                label: 'Pre',
                data: [47, 58, 68, 80, 91],
                backgroundColor: palette.cocoaSoft,
                borderRadius: 4,
              },
              {
                label: 'Post',
                data: [78, 82, 86, 90, 95],
                backgroundColor: palette.mustard.solid,
                borderRadius: 4,
              },
            ],
          },
        },
        chart3: {
          type: 'bar',
          data: {
            labels: ['Open question', 'Needs match', 'Fit check', 'Follow-up'],
            datasets: [{
              label: 'Pass rate (%)',
              data: [89, 84, 78, 81],
              backgroundColor: palette.mustard.soft,
              borderColor: palette.mustard.solid,
              borderWidth: 2,
              borderRadius: 6,
            }],
          },
        },
        chart4: {
          type: 'doughnut',
          data: {
            labels: ['Correct match', 'Partial match', 'Mismatch'],
            datasets: [{
              data: [72, 21, 7],
              backgroundColor: [palette.mustard.solid, palette.avocado.solid, palette.terracotta.solid],
              borderColor: palette.cream,
              borderWidth: 3,
            }],
          },
        },
      },
    };

    // ---- Shared Chart.js options -----------------------------------
    function baseOptions(extra = {}) {
      return {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 600, easing: 'easeOutQuart' },
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              usePointStyle: true,
              pointStyle: 'circle',
              padding: 14,
              color: palette.cocoa,
              font: { weight: '600', size: 11 },
            },
          },
          tooltip: {
            backgroundColor: palette.cocoa,
            titleColor: palette.cream,
            bodyColor: palette.cream,
            padding: 10,
            cornerRadius: 8,
            displayColors: true,
            boxPadding: 4,
          },
        },
        scales: {
          x: {
            grid: { display: false, drawBorder: false },
            ticks: { color: palette.cocoaSoft, font: { size: 11 } },
          },
          y: {
            beginAtZero: true,
            grid: { color: palette.grid, drawBorder: false },
            ticks: { color: palette.cocoaSoft, font: { size: 11 } },
          },
        },
        ...extra,
      };
    }

    function doughnutOptions() {
      return {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '62%',
        animation: { duration: 700, easing: 'easeOutQuart' },
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              usePointStyle: true,
              pointStyle: 'circle',
              padding: 14,
              color: palette.cocoa,
              font: { weight: '600', size: 11 },
            },
          },
          tooltip: {
            backgroundColor: palette.cocoa,
            titleColor: palette.cream,
            bodyColor: palette.cream,
            padding: 10,
            cornerRadius: 8,
            callbacks: {
              label: (ctx) => ` ${ctx.label}: ${ctx.parsed}%`,
            },
          },
        },
      };
    }

    // ---- Merge per-chart option overrides --------------------------
    function buildConfig(cfg) {
      const isDoughnut = cfg.type === 'doughnut';
      const opts = isDoughnut
        ? doughnutOptions()
        : baseOptions(cfg.options ?? {});

      // Deep-ish merge for scales when chart config supplies its own
      if (!isDoughnut && cfg.options?.scales) {
        opts.scales = { ...opts.scales, ...cfg.options.scales };
      }

      return {
        type: cfg.type,
        data: cfg.data,
        options: opts,
      };
    }

    // ---- Instantiate charts ----------------------------------------
    const instances = new Map();

    function renderPanel(companyId) {
      const companyData = data[companyId];
      if (!companyData) return;

      for (let i = 1; i <= 4; i++) {
        const canvas = document.querySelector(`canvas[data-chart="${companyId}-${i}"]`);
        const titleEl = document.querySelector(`[data-chart-title="${companyId}-${i}"]`);
        if (!canvas) continue;

        const key = `${companyId}-${i}`;
        if (!instances.has(key)) {
          const cfg = buildConfig(companyData['chart' + i]);
          instances.set(key, new Chart(canvas, cfg));
        }
        if (titleEl) titleEl.textContent = companyData.titles[i];
      }
    }

    // ---- Tab switching ---------------------------------------------
    const tabs = document.querySelectorAll('[data-company-tab]');
    const panels = document.querySelectorAll('[data-company-panel]');

    function showCompany(id) {
      tabs.forEach(tab => {
        const active = tab.getAttribute('data-company-tab') === id;
        tab.setAttribute('data-active', active ? 'true' : 'false');
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      panels.forEach(panel => {
        const active = panel.getAttribute('data-company-panel') === id;
        if (active) {
          panel.hidden = false;
          renderPanel(id);
        } else {
          panel.hidden = true;
        }
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const id = tab.getAttribute('data-company-tab');
        if (id) showCompany(id);
      });
    });

    // Render the initially visible panel
    const firstActive = document.querySelector('[data-company-tab][data-active="true"]');
    if (firstActive) {
      const id = firstActive.getAttribute('data-company-tab');
      if (id) renderPanel(id);
    }
  </script>
</BaseLayout>
