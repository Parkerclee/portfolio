---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  bareTitle?: boolean; // use `title` verbatim instead of appending the brand suffix
  breadcrumbs?: { name: string; url: string }[];
}

const {
  title,
  description = "Instructional designer using AI as a development partner to build learning experiences that move business outcomes.",
  ogImage = "/og-default.png",
  bareTitle = false,
  breadcrumbs,
} = Astro.props;

const fullTitle = `${title} | Parker Lee · Instructional Designer`;
const pageTitle = bareTitle ? title : fullTitle;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const ogImageURL = new URL(ogImage, Astro.site ?? Astro.url);
const siteUrl = (Astro.site ?? new URL('https://parkerlee.work')).origin;

// Google Search Console verification token (public by design). Overridable via env.
const gscVerification =
  import.meta.env.PUBLIC_GSC_VERIFICATION ?? "MJTIcExX0mZY6hxBsjyGk5tH79aTx26XgHOGqE5nARE";

// Site-wide structured data so Google understands who this is and what he does.
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Parker Lee",
  url: siteUrl,
  jobTitle: "Senior Instructional Designer",
  email: "mailto:parkerclee@gmail.com",
  description:
    "Senior Instructional Designer building AI-augmented learning and custom, company-specific AI training across fraud, lending, and banking operations.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "American Fork",
    addressRegion: "UT",
    addressCountry: "US",
  },
  worksFor: { "@type": "Organization", name: "SoFi" },
  alumniOf: { "@type": "CollegeOrUniversity", name: "Utah Valley University" },
  sameAs: [
    "https://www.linkedin.com/in/parkerclee/",
    "https://github.com/Parkerclee",
  ],
  knowsLanguage: ["English", "French"],
  knowsAbout: [
    "AI in Learning and Development",
    "AI for Knowledge Management",
    "Custom AI training",
    "Company-specific AI training",
    "Instructional design",
    "Learning experience design",
    "Operations training",
    "Fraud, lending, and banking operations training",
    "xAPI",
    "Learning Record Store",
    "Learning analytics",
    "Scenario-based learning",
    "SCORM",
    "Articulate Rise 360",
    "Articulate Storyline",
  ],
};
const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Parker Lee — Instructional Designer",
  url: siteUrl,
};
const breadcrumbLd = breadcrumbs && breadcrumbs.length
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: breadcrumbs.map((b, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: b.name,
        item: new URL(b.url, siteUrl).href,
      })),
    }
  : null;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {gscVerification && <meta name="google-site-verification" content={gscVerification} />}
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Parker Lee · Instructional Designer" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Parker Lee, Instructional Designer" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="Parker Lee, Instructional Designer" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500;1,9..144,600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-cream-50 text-cocoa font-sans min-h-screen flex flex-col">
    <Navigation />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
