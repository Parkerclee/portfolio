---
import Sparkles from './decor/Sparkles.astro';

const currentYear = new Date().getFullYear();
---
<footer class="bg-espresso text-cream/70 mt-auto relative overflow-hidden">
  <!-- Subtle sparkle accents -->
  <Sparkles class="absolute top-2 right-6 w-20 h-auto opacity-50 pointer-events-none" />
  <Sparkles class="absolute bottom-2 left-6 w-20 h-auto opacity-40 pointer-events-none scale-x-[-1]" />

  <div class="max-w-6xl mx-auto px-6 py-12 relative">
    <div class="flex flex-col md:flex-row justify-between items-start gap-8">
      <!-- Left: branding -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <span class="w-9 h-9 rounded-xl bg-primary-500 retro-sheen flex items-center justify-center text-cream font-display font-bold text-base">
            PL
          </span>
          <span class="font-display font-semibold text-cream text-lg">Parker Lee</span>
        </div>
        <p class="text-sm max-w-xs leading-relaxed">
          Instructional designer building AI-powered learning solutions.
          This portfolio was vibe-coded in Cursor.
        </p>
      </div>

      <!-- Center: nav links -->
      <div class="flex gap-12">
        <div>
          <h4 class="text-xs font-display text-accent-500/90 uppercase tracking-widest mb-3">Portfolio</h4>
          <nav class="flex flex-col gap-2">
            <a href="/#case-studies" class="text-sm hover:text-cream transition-colors">Case Studies</a>
            <a href="/demos" class="text-sm hover:text-cream transition-colors">Live Demos</a>
            <a href="/resources" class="text-sm hover:text-cream transition-colors">Free Resources</a>
            <a href="/dashboard" class="text-sm hover:text-cream transition-colors">Dashboard</a>
          </nav>
        </div>
        <div>
          <h4 class="text-xs font-display text-accent-500/90 uppercase tracking-widest mb-3">Connect</h4>
          <nav class="flex flex-col gap-2">
            <a href="/about" class="text-sm hover:text-cream transition-colors">About</a>
            <a href="/contact" class="text-sm hover:text-cream transition-colors">Contact</a>
            <a href="https://github.com/Parkerclee" target="_blank" rel="noopener" class="text-sm hover:text-cream transition-colors">GitHub</a>
          </nav>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-cocoa mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs">&copy; {currentYear} Parker Lee. Built with Astro + Tailwind CSS.</p>
      <div class="flex gap-4">
        <a href="https://github.com/Parkerclee" target="_blank" rel="noopener" aria-label="GitHub"
           class="hover:text-cream transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/parkerclee/" target="_blank" rel="noopener" aria-label="LinkedIn"
           class="hover:text-cream transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
