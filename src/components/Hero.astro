---
import MoonStar from './decor/MoonStar.astro';
import Sparkles from './decor/Sparkles.astro';
---
<section class="relative overflow-hidden bg-paper paper-bg">
  <!-- Soft gradient orbs -->
  <div class="absolute -top-44 -right-32 w-[520px] h-[520px] rounded-full bg-accent-400/25 blur-3xl"></div>
  <div class="absolute -bottom-48 -left-40 w-[440px] h-[440px] rounded-full bg-secondary-300/25 blur-3xl"></div>

  <!-- Celestial accents -->
  <MoonStar class="absolute top-10 left-6 sm:left-12 w-10 sm:w-14 h-auto opacity-90 hidden sm:block" />
  <Sparkles class="hidden md:block absolute bottom-16 right-10 w-28 lg:w-36 h-auto opacity-80 pointer-events-none" />

  <div class="relative max-w-6xl mx-auto px-6 py-24 sm:py-32 lg:py-40">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="hero-animate inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-400/20 border border-accent-500/40 text-cocoa text-xs font-semibold mb-6">
        <span class="w-2 h-2 rounded-full bg-secondary-500"></span>
        AI-Powered Instructional Design
      </div>

      <!-- Heading -->
      <h1 class="hero-animate hero-delay-1 font-display font-semibold text-cocoa text-4xl sm:text-5xl lg:text-6xl leading-[1.05] tracking-tight">
        I build learning experiences
        <span class="italic text-primary-600">that go beyond slides.</span>
      </h1>

      <!-- Subheading -->
      <p class="hero-animate hero-delay-2 mt-6 text-lg sm:text-xl text-cocoa/70 leading-relaxed max-w-2xl">
        Instructional designer who leverages AI to create interactive simulations,
        data-driven evaluations, and code-built learning tools. This portfolio was
        vibe-coded entirely in Cursor.
      </p>

      <!-- CTAs -->
      <div class="hero-animate hero-delay-3 mt-10 flex flex-wrap gap-4">
        <a href="/#case-studies"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-primary-500 text-cream font-semibold retro-sheen
                  hover:bg-primary-600 transition-all hover:shadow-lg hover:shadow-primary-600/30">
          View Case Studies
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/demos"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-cocoa/25 text-cocoa font-semibold
                  hover:border-primary-500 hover:text-primary-600 transition-all">
          Try Live Demos
        </a>
      </div>

      <!-- Quick stats -->
      <div class="hero-animate hero-delay-4 mt-16 flex gap-10 sm:gap-16">
        <div>
          <p class="font-display font-semibold text-3xl text-primary-600">3</p>
          <p class="text-sm text-cocoa/60 mt-1">Case Studies</p>
        </div>
        <div>
          <p class="font-display font-semibold text-3xl text-secondary-600">2</p>
          <p class="text-sm text-cocoa/60 mt-1">Live Demos</p>
        </div>
        <div>
          <p class="font-display font-semibold text-3xl text-accent-600">1</p>
          <p class="text-sm text-cocoa/60 mt-1">Analytics Dashboard</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-animate {
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-delay-1 { animation-delay: 0.15s; }
  .hero-delay-2 { animation-delay: 0.3s; }
  .hero-delay-3 { animation-delay: 0.45s; }
  .hero-delay-4 { animation-delay: 0.6s; }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
