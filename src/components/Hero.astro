---
// Bold, flat hero — solid color, no gradients, orbs, or decorative SVGs.
---
<section class="bg-cream-50 border-b-4 border-cocoa">
  <div class="max-w-6xl mx-auto px-6 py-16 sm:py-24 lg:py-28">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="hero-animate inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent-500 text-cocoa text-xs font-bold uppercase tracking-wide mb-6">
        <span class="w-2 h-2 rounded-full bg-cocoa"></span>
        AI for L&D · Knowledge Management · Custom Training
      </div>

      <!-- Heading -->
      <h1 class="hero-animate hero-delay-1 font-display font-bold text-cocoa text-4xl sm:text-5xl lg:text-6xl leading-[1.04] tracking-tight">
        I build learning experiences
        <span class="text-primary-600">that go beyond slides.</span>
      </h1>

      <!-- Subheading -->
      <p class="hero-animate hero-delay-2 mt-5 text-base sm:text-lg text-cocoa/80 leading-relaxed max-w-2xl">
        I help companies put AI to work in their L&D and knowledge management, and build custom
        training for their own tools and workflows. The kind that proves it changed behavior, not
        just that someone clicked through.
      </p>

      <!-- CTAs -->
      <div class="hero-animate hero-delay-3 mt-8 flex flex-wrap gap-3">
        <a href="/#case-studies"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-primary-500 text-cream font-semibold retro-sheen
                  hover:bg-primary-600 transition-colors">
          View Case Studies
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/demos"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-full border-2 border-cocoa text-cocoa font-semibold
                  hover:bg-cocoa hover:text-cream transition-colors">
          Try Live Demos
        </a>
      </div>

      <!-- Quick stats -->
      <div class="hero-animate hero-delay-4 mt-12 grid grid-cols-3 gap-4 max-w-lg">
        <div class="border-t-4 border-primary-500 pt-3">
          <p class="font-display font-bold text-3xl sm:text-4xl text-cocoa">6</p>
          <p class="text-xs sm:text-sm text-cocoa/60 mt-1">Real case studies</p>
        </div>
        <div class="border-t-4 border-secondary-500 pt-3">
          <p class="font-display font-bold text-3xl sm:text-4xl text-cocoa">10+</p>
          <p class="text-xs sm:text-sm text-cocoa/60 mt-1">Live demos</p>
        </div>
        <div class="border-t-4 border-accent-500 pt-3">
          <p class="font-display font-bold text-3xl sm:text-4xl text-cocoa">3</p>
          <p class="text-xs sm:text-sm text-cocoa/60 mt-1">Free resources</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-animate {
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-delay-1 { animation-delay: 0.12s; }
  .hero-delay-2 { animation-delay: 0.24s; }
  .hero-delay-3 { animation-delay: 0.36s; }
  .hero-delay-4 { animation-delay: 0.48s; }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-animate { animation: none; opacity: 1; transform: none; }
  }
</style>
