---
interface Props {
  company: string;
  industry: string;
  challenge: string;
  deliverable: string;
  color: string;          // "terracotta" | "avocado" | "mustard"
  slug: string;
  initials: string;       // 2-letter abbreviation for the logo placeholder
}

const { company, industry, challenge, deliverable, color, slug, initials } = Astro.props;

const colorMap: Record<string, { bg: string; text: string; border: string; badge: string }> = {
  terracotta: {
    bg: 'bg-primary-100',
    text: 'text-primary-700',
    border: 'border-primary-200',
    badge: 'bg-primary-100 text-primary-700',
  },
  avocado: {
    bg: 'bg-secondary-100',
    text: 'text-secondary-600',
    border: 'border-secondary-200',
    badge: 'bg-secondary-100 text-secondary-700',
  },
  mustard: {
    bg: 'bg-accent-400/25',
    text: 'text-accent-700',
    border: 'border-accent-500/40',
    badge: 'bg-accent-400/25 text-accent-700',
  },
};

const colors = colorMap[color] || colorMap.terracotta;
---
<a href={`/case-studies/${slug}`}
   class="group block rounded-3xl border border-cocoa/15 bg-paper p-6 sm:p-8
          hover:border-primary-400 hover:shadow-xl hover:shadow-primary-600/10
          transition-all duration-300">
  <!-- Company header -->
  <div class="flex items-center gap-3 mb-5">
    <span class={`w-11 h-11 rounded-xl ${colors.bg} ${colors.text} flex items-center justify-center font-display font-bold text-sm border ${colors.border}`}>
      {initials}
    </span>
    <div>
      <p class="font-display font-semibold text-cocoa">{company}</p>
      <p class="text-xs text-cocoa/60">{industry}</p>
    </div>
  </div>

  <!-- Challenge -->
  <p class="text-cocoa/70 leading-relaxed mb-5">
    {challenge}
  </p>

  <!-- Deliverable badge -->
  <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold ${colors.badge}`}>
    {deliverable}
  </span>

  <!-- Read more arrow -->
  <div class="mt-6 flex items-center gap-2 text-sm font-semibold text-primary-600
              group-hover:gap-3 transition-all">
    Read case study
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </div>
</a>
