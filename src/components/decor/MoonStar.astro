---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<svg
  viewBox="0 0 64 64"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  focusable="false"
>
  <!-- crescent moon -->
  <path
    d="M38 12 A20 20 0 1 0 38 52 A15 15 0 1 1 38 12 Z"
    fill="#D9A441"
    stroke="#553824"
    stroke-width="2.25"
    stroke-linejoin="round"
  />
  <!-- sparkles -->
  <path
    d="M12 10 L14 16 L20 18 L14 20 L12 26 L10 20 L4 18 L10 16 Z"
    fill="#E6B85A"
    stroke="#553824"
    stroke-width="1.5"
    stroke-linejoin="round"
  />
  <path
    d="M54 40 L55.5 44 L59.5 45.5 L55.5 47 L54 51 L52.5 47 L48.5 45.5 L52.5 44 Z"
    fill="#E6B85A"
    stroke="#553824"
    stroke-width="1.25"
    stroke-linejoin="round"
  />
  <circle cx="14" cy="46" r="2" fill="#C4663D" stroke="#553824" stroke-width="1.25" />
</svg>
