---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<svg
  viewBox="-2 -2 68 68"
  xmlns="http://www.w3.org/2000/svg"
  class={`decor-float ${className}`}
  aria-hidden="true"
  focusable="false"
>
  <!-- crescent moon: two equal-radius circle arcs (left edge, then the bite) -->
  <path
    d="M38 10.8 A22 22 0 1 0 38 53.2 A22 22 0 0 1 38 10.8 Z"
    fill="#E0A92E"
    stroke="#553824"
    stroke-width="2"
    stroke-linejoin="round"
  />
  <!-- four-point sparkle, upper-left -->
  <g class="decor-twinkle" transform="translate(12 13) scale(0.6)">
    <path d="M0,-11 C1.4,-4 4,-1.4 11,0 C4,1.4 1.4,4 0,11 C-1.4,4 -4,1.4 -11,0 C-4,-1.4 -1.4,-4 0,-11 Z"
          fill="#F2BE3A" stroke="#553824" stroke-width="1.7" stroke-linejoin="round" />
  </g>
  <!-- smaller sparkle, lower-right -->
  <g class="decor-twinkle-2" transform="translate(55 45) scale(0.4)">
    <path d="M0,-11 C1.4,-4 4,-1.4 11,0 C4,1.4 1.4,4 0,11 C-1.4,4 -4,1.4 -11,0 C-4,-1.4 -1.4,-4 0,-11 Z"
          fill="#F8D269" stroke="#553824" stroke-width="2.2" stroke-linejoin="round" />
  </g>
  <circle cx="14" cy="48" r="2" fill="#C4663D" />
</svg>
