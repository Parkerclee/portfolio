---
interface Props {
  class?: string;
  top?: string;    // background color of the section above
  bottom?: string; // background color of the section below
  flip?: boolean;  // use the alternate wave shape (for visual variety)
}
const {
  class: className = '',
  top = '#FCFCF9',
  bottom = '#F7F7F2',
  flip = false,
} = Astro.props;

// Crest path; the fill closes down to the bottom edge so the wave IS the
// color boundary between the two sections.
const crest = flip
  ? 'M0,34 C200,58 360,12 540,34 S840,56 1020,30 1200,36'
  : 'M0,35 C150,9 300,52 450,35 S750,9 900,35 S1150,52 1200,35';
const fill = `${crest} L1200,70 L0,70 Z`;
---
<div class={`pointer-events-none w-full overflow-hidden ${className}`} aria-hidden="true" style={`background:${top}`}>
  <svg
    viewBox="0 0 1200 70"
    preserveAspectRatio="none"
    xmlns="http://www.w3.org/2000/svg"
    class="block w-full h-10 sm:h-12"
    focusable="false"
  >
    <path d={fill} fill={bottom} />
    <path d={crest} fill="none" stroke="#5C8A2E" stroke-width="2" stroke-linecap="round" opacity="0.7" />
  </svg>
</div>
