---
interface Props {
  class?: string;
  flip?: boolean;
}
const { class: className = '', flip = false } = Astro.props;
---
<div class={`pointer-events-none w-full overflow-hidden ${className}`} aria-hidden="true">
  <svg
    viewBox="0 0 1200 80"
    preserveAspectRatio="none"
    xmlns="http://www.w3.org/2000/svg"
    class={`w-full h-14 sm:h-16 ${flip ? 'scale-y-[-1]' : ''}`}
    focusable="false"
  >
    <!-- main wavy line (meadow green, much wavier) -->
    <path
      d="M0 40 C 100 8, 200 72, 300 40 S 500 8, 600 40 S 800 72, 900 40 S 1100 8, 1200 40"
      stroke="#5C8A2E"
      stroke-width="2.5"
      fill="none"
      stroke-linecap="round"
    />
    <!-- soft echo wave below for depth -->
    <path
      d="M0 54 C 100 28, 200 80, 300 54 S 500 28, 600 54 S 800 80, 900 54 S 1100 28, 1200 54"
      stroke="#8FBF54"
      stroke-width="1.6"
      fill="none"
      stroke-linecap="round"
      opacity="0.45"
    />
    <!-- three small stars scattered above the wave -->
    <path d="M290 14 L292 20 L298 21 L292 22 L290 28 L288 22 L282 21 L288 20 Z"
          fill="#F2BE3A" stroke="#3D2818" stroke-width="0.9" stroke-linejoin="round" />
    <path d="M700 10 L702 16 L708 17 L702 18 L700 24 L698 18 L692 17 L698 16 Z"
          fill="#F8D269" stroke="#3D2818" stroke-width="0.9" stroke-linejoin="round" />
    <path d="M990 18 L991.5 22 L995.5 23 L991.5 24 L990 28 L988.5 24 L984.5 23 L988.5 22 Z"
          fill="#F2BE3A" stroke="#3D2818" stroke-width="0.8" stroke-linejoin="round" />
  </svg>
</div>
