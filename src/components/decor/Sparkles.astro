---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<svg
  viewBox="0 0 120 80"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  focusable="false"
>
  <!-- tiny scattered sparkles / stars -->
  <path d="M18 14 L20 20 L26 22 L20 24 L18 30 L16 24 L10 22 L16 20 Z"
        fill="#D9A441" stroke="#553824" stroke-width="1.2" stroke-linejoin="round" />
  <path d="M96 20 L97.5 24 L101.5 25.5 L97.5 27 L96 31 L94.5 27 L90.5 25.5 L94.5 24 Z"
        fill="#E6B85A" stroke="#553824" stroke-width="1" stroke-linejoin="round" />
  <path d="M58 54 L59.5 58 L63.5 59.5 L59.5 61 L58 65 L56.5 61 L52.5 59.5 L56.5 58 Z"
        fill="#D9A441" stroke="#553824" stroke-width="1" stroke-linejoin="round" />
  <circle cx="42" cy="32" r="1.6" fill="#C4663D" />
  <circle cx="78" cy="48" r="1.4" fill="#6E7C3F" />
  <circle cx="108" cy="58" r="1.2" fill="#C4663D" />
