---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
const star = 'M0,-11 C1.4,-4 4,-1.4 11,0 C4,1.4 1.4,4 0,11 C-1.4,4 -4,1.4 -11,0 C-4,-1.4 -1.4,-4 0,-11 Z';
---
<svg
  viewBox="0 0 120 80"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  focusable="false"
>
  <g class="decor-twinkle" transform="translate(18 22) scale(0.95)">
    <path d={star} fill="#F2BE3A" stroke="#553824" stroke-width="1.3" stroke-linejoin="round" />
  </g>
  <g class="decor-twinkle-2" transform="translate(96 24) scale(0.6)">
    <path d={star} fill="#F8D269" stroke="#553824" stroke-width="1.7" stroke-linejoin="round" />
  </g>
  <g class="decor-twinkle" transform="translate(58 58) scale(0.5)">
    <path d={star} fill="#E8B84F" stroke="#553824" stroke-width="2" stroke-linejoin="round" />
  </g>
  <circle class="decor-twinkle-2" cx="42" cy="34" r="1.8" fill="#C4663D" />
  <circle cx="78" cy="48" r="1.5" fill="#6E7C3F" />
  <circle class="decor-twinkle" cx="108" cy="60" r="1.4" fill="#C4663D" />
</svg>
